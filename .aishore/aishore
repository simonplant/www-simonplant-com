# Portable date helpers (GNU date uses -Iseconds / -d; BSD date does not)
portable_date_iso() {
    date -Iseconds 2>/dev/null || {
        local ts
        ts=$(date +%Y-%m-%dT%H:%M:%S%z)
        # Insert colon in timezone offset: +0700 -> +07:00
        printf '%s:%s\n' "${ts%??}" "${ts: -2}"
    }
}

portable_date_epoch() {
    local input="$1"
    date -d "$input" +%s 2>/dev/null || \
        date -j -f "%Y-%m-%dT%H:%M:%S" "${input:0:19}" +%s 2>/dev/null || \
        echo 0
}

# Portable UUID v4 generator for session IDs
_generate_uuid() {
    if command -v uuidgen &>/dev/null; then
        uuidgen | tr '[:upper:]' '[:lower:]'
    elif [[ -r /proc/sys/kernel/random/uuid ]]; then
        cat /proc/sys/kernel/random/uuid
    elif command -v python3 &>/dev/null; then
        python3 -c "import uuid; print(uuid.uuid4())"
    else
        # Fallback: hex from /dev/urandom
        od -An -tx1 -N16 /dev/urandom 2>/dev/null | tr -d ' \n' | \
            sed 's/^\(.\{8\}\)\(.\{4\}\).\(.\{3\}\).\(.\{3\}\)\(.\{12\}\)$/\1-\2-4\3-a\4-\5/'
    fi
}

