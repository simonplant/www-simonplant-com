# Error handling convention:
#   - All functions signal failure with: log_error "message"; return 1
#   - Functions must NEVER call exit 1 — only return 1
#   - Only main() and pre-flight guards (acquire_lock, require_tool) may call exit
#   - Every return 1 must be preceded by a log_error call (directly or via a called function)
log_header()  { echo -e "\n${BLUE}════════════════════════════════════════${NC}\n${BLUE}  $1${NC}\n${BLUE}════════════════════════════════════════${NC}"; }
log_subheader() { echo -e "\n${CYAN}─── $1 ───${NC}"; }
log_success() { echo -e "${GREEN}✓ $1${NC}"; }
log_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }
log_error()   { echo -e "${RED}✗ $1${NC}" >&2; }
log_info()    { echo -e "${CYAN}$1${NC}"; }
log_agent()   { echo -e "${MAGENTA}[$1]${NC} $2"; }

# Validate that a CLI flag's argument is a positive integer.
# Usage: require_numeric_arg "--flag-name" "$value" "$#" || return 1
require_numeric_arg() {
    local flag="$1" value="$2" argc="$3"
    if [[ "$argc" -eq 0 || ! "$value" =~ ^[0-9]+$ ]]; then
        log_error "$flag requires a numeric argument"
        return 1
    fi
}

# Validate that a CLI flag has a non-empty, non-flag value.
# Usage: validate_arg "--flag" "${2:-}" || return 1
validate_arg() {
    local flag="$1" val="$2"
    if [[ -z "$val" || "$val" == --* ]]; then
        log_error "$flag requires a value"
        return 1
    fi
}

# parse_opts — Declarative option parser for cmd_* functions.
# Sets variables in the caller's scope via Bash dynamic scoping.
# Callers must declare target variables as local before calling.
#
# Usage: parse_opts [--positional] SPEC... -- "$@"
#
# SPEC types (TYPE:VAR:FLAGS where FLAGS are pipe-separated):
#   bool:VAR:--flag|-f        Set VAR=true
#   val:VAR:--flag            Set VAR=<next arg> (validates non-empty)
#   num:VAR:--flag            Set VAR=<next arg> (validates numeric)
#   arr:VAR:--flag            Append <next arg> to VAR array (validates non-empty)
#   passval:--flag            Pass flag + value to _PARSE_REMAINING (for custom handling)
#
# Options:
#   --positional  Allow non-flag positional args (collected in _PARSE_REMAINING).
#                 Without this, any non-flag arg triggers an error.
#
# Unknown --* flags always trigger an error.
# After parsing, _PARSE_REMAINING holds passval items and (if --positional) positional args.
parse_opts() {
    local _po_positional=false
    local -a _po_specs=()
    while [[ $# -gt 0 && "$1" != "--" ]]; do
        if [[ "$1" == "--positional" ]]; then
            _po_positional=true
        else
            _po_specs+=("$1")
        fi
        shift
    done
    [[ "${1:-}" == "--" ]] && shift

    _PARSE_REMAINING=()

    while [[ $# -gt 0 ]]; do
        local _po_matched=false _po_s
        for _po_s in "${_po_specs[@]}"; do
            local _po_type _po_rest _po_var _po_flags
            _po_type="${_po_s%%:*}"
            _po_rest="${_po_s#*:}"
            if [[ "$_po_type" == "passval" ]]; then
                _po_var=""
                _po_flags="$_po_rest"
            else
                _po_var="${_po_rest%%:*}"
                _po_flags="${_po_rest#*:}"
            fi

            local _po_f _po_sifs="$IFS"
            IFS='|'
            for _po_f in $_po_flags; do
                IFS="$_po_sifs"
                [[ "$1" != "$_po_f" ]] && continue
                case "$_po_type" in
                    bool)
                        eval "${_po_var}=true"
                        shift ;;
                    val)
                        validate_arg "$1" "${2:-}" || return 1
                        eval "${_po_var}=\"\$2\""
                        shift 2 ;;
                    num)
                        local _po_fn="$1"; shift
                        require_numeric_arg "$_po_fn" "${1:-}" "$#" || return 1
                        eval "${_po_var}=\"\$1\""
                        shift ;;
                    arr)
                        validate_arg "$1" "${2:-}" || return 1
                        eval "${_po_var}+=(\"\$2\")"
                        shift 2 ;;
                    passval)
                        if [[ -n "${2:-}" && "${2:-}" != --* ]]; then
                            _PARSE_REMAINING+=("$1" "$2")
                            shift 2
                        else
                            _PARSE_REMAINING+=("$1")
                            shift
                        fi ;;
                esac
                _po_matched=true
                break
            done
            IFS="$_po_sifs"
            [[ "$_po_matched" == "true" ]] && break
        done

        if [[ "$_po_matched" == "false" ]]; then
            if [[ "$1" == --* || "$1" == -* ]]; then
                log_error "Unknown option: $1"
                return 1
            fi
            if [[ "$_po_positional" == "true" ]]; then
                _PARSE_REMAINING+=("$1")
            else
                log_error "Unknown option: $1"
                return 1
            fi
            shift
        fi
    done
}

# Truncate file content to last OUTPUT_TRUNCATE_LINES lines, prepending notice if truncated.
# Usage: result=$(truncate_output "$tmpfile")
truncate_output() {
    local file="$1"
    local total_lines
    total_lines=$(wc -l < "$file" 2>/dev/null || echo 0)
    local output
    output=$(tail -n "$OUTPUT_TRUNCATE_LINES" "$file" 2>/dev/null || true)
    if [[ "$total_lines" -gt "$OUTPUT_TRUNCATE_LINES" ]]; then
        output="[... output truncated, showing last $OUTPUT_TRUNCATE_LINES of $total_lines lines]"$'\n'"$output"
    fi
    printf '%s' "$output"
}

# Run a command with optional timeout, capturing output to a file.
# Usage: run_timed_command <command_string> <output_file>
# Returns: 0 on success, 1 on failure. Output is written to output_file.
run_timed_command() {
    local cmd="$1"
    local outfile="$2"
    if [[ -n "$TIMEOUT_CMD" ]]; then
        "$TIMEOUT_CMD" "$CORE_TIMEOUT" bash -c "$cmd" >"$outfile" 2>&1
    else
        bash -c "$cmd" >"$outfile" 2>&1
    fi
}

# Ensure agent's work is committed (safety net if agent missed it)
# Excludes backlog/ and .aishore/ — only code changes belong on the feature branch.
_safety_commit() {
    local item_id="$1"
    if ! git diff -- ':!backlog/' ':!.aishore/' --quiet 2>/dev/null \
        || ! git diff --cached -- ':!backlog/' ':!.aishore/' --quiet 2>/dev/null \
        || [[ -n "$(git ls-files --others --exclude-standard -- ':!backlog/' ':!.aishore/' 2>/dev/null)" ]]; then
        log_warning "Agent left uncommitted changes — committing"
        local summary
        summary=$(jq -r '.summary // ""' "$STATUS_DIR/result.json" 2>/dev/null || echo "")
        summary="${summary:0:500}"
        git add -A -- ':!backlog/' ':!.aishore/' || { log_error "git add failed in safety commit"; return 1; }
        git commit -m "feat($item_id): ${summary:-implement sprint item}

Co-Authored-By: Claude <noreply@anthropic.com>" || { log_error "git commit failed in safety commit"; return 1; }
    fi
}

# Remove a git worktree and optionally its branch
_remove_worktree() {
    local wt_dir="$1" branch="${2:-}"
    cd "$PROJECT_ROOT" || { log_error "Cannot cd to $PROJECT_ROOT"; return 1; }
    git worktree remove "$wt_dir" --force 2>/dev/null || true
    if [[ -d "$wt_dir" ]]; then rm -rf "$wt_dir" 2>/dev/null || true; fi
    if [[ -n "$branch" ]]; then git branch -D "$branch" 2>/dev/null || true; fi
}

