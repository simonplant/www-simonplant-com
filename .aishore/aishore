_pick_by_id() {
    local specific_id="$1"
    local source_file="$STATUS_DIR/.item_source"

    local backlog
    backlog=$(resolve_backlog_file "$specific_id") || return 1
    local full_item
    full_item=$(find_item "$specific_id") || return 1

    # Project to sprint fields
    local item_json
    item_json=$(printf '%s\n' "$full_item" | jq "$ITEM_PROJECTION")

    # Extract all needed scalar fields from full_item in one jq pass
    local item_intent item_status deps_json
    IFS=$'\t' read -r item_intent item_status deps_json < <(
        printf '%s\n' "$full_item" | jq -r '[(.intent // ""), (.status // "todo"), (.dependsOn // null | tojson)] | @tsv'
    )
    [[ "$deps_json" == "null" ]] && deps_json=""

    # Enforce commander's intent — no intent, no sprint
    if [[ -z "$item_intent" ]]; then
        log_error "Item $specific_id has no intent — set one with: .aishore/aishore backlog edit $specific_id --intent \"...\""
        log_error "Commander's intent defines what must be true when done. No intent, no sprint."
        return 1
    elif [[ ${#item_intent} -lt 20 ]]; then
        log_error "Item $specific_id intent is too short — must be a clear directive, not a label"
        log_error "Current: \"$item_intent\""
        return 1
    fi

    if [[ "$item_status" == "done" ]]; then
        log_warning "Item $specific_id is already completed — re-running"
    fi
    # Check for unmet dependencies
    if [[ -n "$deps_json" && "$deps_json" != "null" ]]; then
        local all_done_ids
        all_done_ids=$(collect_done_ids)
        local unmet
        unmet=$(printf '%s\n' "$deps_json" | jq -r --argjson done_ids "$all_done_ids" '.[] | select(. as $dep | $done_ids | index($dep) == null)' 2>/dev/null)
        if [[ -n "$unmet" ]]; then
            log_warning "Item $specific_id has unmet dependencies: $(printf '%s\n' "$unmet" | tr '\n' ', ' | sed 's/,$//')"
        fi
    fi
    printf '%s\n' "$backlog" > "$source_file"
    printf '%s\n' "$item_json"
}

_warn_unpickable() {
    local skip_json="$1" done_ids_json="$2"
    local _bf
    for _bf in "${BACKLOG_FILES[@]}"; do
        [[ -f "$BACKLOG_DIR/$_bf" ]] || continue
        local _warnings
        _warnings=$(jq -r --argjson skip "$skip_json" --argjson done_ids "$done_ids_json" '
            .items[] |
            select(.readyForSprint == true and (.passes == false or .passes == null) and (.status == "todo" or .status == null)) |
            select(.id as $id | $skip | index($id) | not) |
            if .dependsOn != null and (.id as $self | .dependsOn | index($self) != null) then
                .id + "\tself-referencing dependency"
            elif .intent == null or .intent == "" then
                .id + "\tintent missing"
            elif (.intent | length) < 20 then
                .id + "\tintent \(.intent | length) chars, need >=20"
            else empty end
        ' "$BACKLOG_DIR/$_bf" 2>/dev/null || true)
        if [[ -n "$_warnings" ]]; then
            while IFS=$'\t' read -r _wid _wreason; do
                log_warning "Skipping $_wid: $_wreason"
            done <<< "$_warnings"
        fi
    done
}

_pick_auto() {
    local skip_ids="${1:-}"
    local source_file="$STATUS_DIR/.item_source"

    # Build skip list as JSON array for jq
    local skip_json="[]"
    if [[ -n "$skip_ids" ]]; then
        skip_json=$(_to_json_array "$skip_ids")
    fi

    # Build list of done item IDs from both backlogs for dependency checking
    local done_ids_json
    done_ids_json=$(collect_done_ids)

    _warn_unpickable "$skip_json" "$done_ids_json"

    # Auto-pick: highest priority ready item across ALL declared backlog files
    local all_candidates="[]"
    _collect_candidates() {
        local backlog="$1"
        [[ -f "$BACKLOG_DIR/$backlog" ]] || return 0
        local candidates
        candidates=$(jq -r --argjson skip "$skip_json" --argjson done_ids "$done_ids_json" --arg core_healthy "$CORE_HEALTHY" --arg src "$backlog" '
            '"$PICKABLE_ITEMS_FILTER"' |
            [.[] | '"$ITEM_PROJECTION"' + {_source: $src}]
        ' "$BACKLOG_DIR/$backlog" 2>/dev/null || echo "[]")
        all_candidates=$(printf '%s\n%s\n' "$all_candidates" "$candidates" | jq -s 'add // []')
    }
    map_backlog_files _collect_candidates

    # Pick highest priority across all files
    local best
    best=$(printf '%s\n' "$all_candidates" | jq -r "$JQ_PRIO_RANK"'
        sort_by([(if .category == "heal" then 0 else 1 end), (.priority // "should" | prio_rank)]) | first // empty
    ' 2>/dev/null)

    if [[ -n "$best" && "$best" != "null" ]]; then
        local best_source
        best_source=$(printf '%s\n' "$best" | jq -r '._source')
        local item_json
        item_json=$(printf '%s\n' "$best" | jq 'del(._source)')
        printf '%s\n' "$best_source" > "$source_file"
        printf '%s\n' "$item_json"
        return 0
    fi

    # Callers provide context-appropriate messages (auto-mode: drained; manual: no ready items)
    return 1
}

pick_item() {
    local specific_id="${1:-}"
    local skip_ids="${2:-}"
    if [[ -n "$specific_id" ]]; then
        _pick_by_id "$specific_id"
    else
        _pick_auto "$skip_ids"
    fi
}

get_item_source() {
    local source_file="$STATUS_DIR/.item_source"
    [[ -f "$source_file" ]] && cat "$source_file" || echo ""
}

