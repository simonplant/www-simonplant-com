# Build standard groom/review context args: all backlog files + recent sprints
# _build_groom_context, protect_items_from_groom, snapshot_backlogs, enforce_groom_limits,
# print_groom_diff, run_groom_flow — extracted to .aishore/lib/cmd-groom.sh (lazy-loaded via _load_module)

# cmd_review — extracted to .aishore/lib/cmd-review.sh (lazy-loaded via _load_module)


# _status_output, cmd_status — extracted to .aishore/lib/cmd-status.sh (lazy-loaded via _load_module)

# Check prerequisites for init: git, claude, jq
cmd_version() {
    echo "aishore version $AISHORE_VERSION"
}

# ============================================================================
# BACKLOG CRUD — extracted to .aishore/lib/cmd-backlog-read.sh (lazy-loaded via _load_module)
# Write commands (add, edit, populate) in .aishore/lib/cmd-backlog-write.sh
# ============================================================================

# cmd_clean, _archive_done_items — extracted to .aishore/lib/cmd-clean.sh (lazy-loaded via _load_module)

# cmd_usage, cmd_help, _help_* — extracted to .aishore/lib/cmd-help.sh (lazy-loaded via _load_module)

# ============================================================================
# MAIN
# ============================================================================

main() {
    mkdir -p "$STATUS_DIR" "$LOGS_DIR" "$ARCHIVE_DIR"

    local cmd="${1:-usage}"
    shift || true

    case "$cmd" in
        run|auto) cmd_run "$@" ;;
        backlog) _load_module cmd-backlog-read; cmd_backlog "$@" ;;
        groom)   _load_module cmd-groom; cmd_groom "$@" ;;
        review)  _load_module cmd-review; cmd_review "$@" ;;
        status)  _load_module cmd-status; cmd_status "$@" ;;
        update)  _load_module cmd-update; cmd_update "$@" ;;
        clean)   _load_module cmd-clean; cmd_clean "$@" ;;
        init)    _load_module cmd-init; cmd_init "$@" ;;
        version|-v|--version) cmd_version ;;
        help|-h|--help) _load_module cmd-help; cmd_help "$@" ;;
        usage) _load_module cmd-help; cmd_usage ;;
        *)
            log_error "Unknown command: $cmd"
            _load_module cmd-help; cmd_usage >&2
            exit 1
            ;;
    esac
}

main "$@"
