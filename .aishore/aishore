# MAIN
# ============================================================================

main() {
    mkdir -p "$STATUS_DIR" "$LOGS_DIR" "$ARCHIVE_DIR"
    _load_module backlog-dal

    local cmd="${1:-usage}"
    shift || true

    case "$cmd" in
        run) cmd_run "$@" ;;
        backlog) _load_module cmd-backlog-read; cmd_backlog "$@" ;;
        groom)    _load_module cmd-groom; cmd_groom "$@" ;;
        scaffold) _load_module cmd-scaffold; cmd_scaffold "$@" ;;
        refine)  _load_module cmd-refine; cmd_refine "$@" ;;
        review)  _load_module cmd-review; cmd_review "$@" ;;
        status)  _load_module cmd-status; cmd_status "$@" ;;
        update)  _load_module cmd-update; cmd_update "$@" ;;
        checksums) _load_module cmd-update; cmd_checksums "$@" ;;
        clean)   _load_module cmd-clean; cmd_clean "$@" ;;
        init)    _load_module cmd-init; cmd_init "$@" ;;
        version|-v|--version) cmd_version ;;
        help|-h|--help) _load_module cmd-help; cmd_help "$@" ;;
        usage) _load_module cmd-help; cmd_usage ;;
        *)
            log_error "Unknown command: $cmd"
            _load_module cmd-help; cmd_usage >&2
            exit 1
            ;;
    esac
}

main "$@"
