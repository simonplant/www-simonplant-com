cleanup_exit() {
    # Restore tool file permissions on unexpected exit
    _unlock_tool_files 2>/dev/null || true
    # Clean up worktree directory but KEEP the branch so work is recoverable
    if [[ -n "$AISHORE_WORKTREE_DIR" ]]; then
        _remove_worktree "$AISHORE_WORKTREE_DIR"
        AISHORE_WORKTREE_DIR=""
        if [[ -n "$AISHORE_FEATURE_BRANCH" ]]; then
            log_warning "Branch '$AISHORE_FEATURE_BRANCH' preserved — recover with: git checkout $AISHORE_FEATURE_BRANCH"
            AISHORE_FEATURE_BRANCH=""
        fi
    fi
    release_lock
    [[ -n "$AISHORE_TMPDIR" && -d "$AISHORE_TMPDIR" ]] && rm -rf "$AISHORE_TMPDIR"
    return 0
}
trap cleanup_exit EXIT

