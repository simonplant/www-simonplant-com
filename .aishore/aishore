# Portable date helpers (GNU date uses -Iseconds / -d; BSD date does not)
portable_date_iso() {
    date -Iseconds 2>/dev/null || {
        local ts
        ts=$(date +%Y-%m-%dT%H:%M:%S%z)
        # Insert colon in timezone offset: +0700 -> +07:00
        printf '%s:%s\n' "${ts%??}" "${ts: -2}"
    }
}

portable_date_epoch() {
    local input="$1"
    date -d "$input" +%s 2>/dev/null || \
        date -j -f "%Y-%m-%dT%H:%M:%S" "${input:0:19}" +%s 2>/dev/null || \
        echo 0
}

