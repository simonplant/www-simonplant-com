print_batch_summary() {
    local batch_start="$1"
    local -n _results=$2
    local -n _items=$3
    local -n _times=$4
    local -n _failed_ids=$5
    local -n _skipped=$6

    local batch_elapsed=$(( $(date +%s) - batch_start ))
    local total=${#_results[@]}
    local total_passed=0
    local total_failed=0

    for r in "${_results[@]}"; do
        if [[ "$r" == "pass" ]]; then
            total_passed=$((total_passed + 1))
        else
            total_failed=$((total_failed + 1))
        fi
    done

    echo ""
    log_header "Batch Summary"
    printf "  %-8s %-12s %-8s %s\n" "Sprint" "Item" "Status" "Elapsed"
    printf "  %-8s %-12s %-8s %s\n" "------" "----" "------" "-------"

    for ((idx=0; idx<total; idx++)); do
        local status_display
        if [[ "${_results[$idx]}" == "pass" ]]; then
            status_display="${GREEN}pass${NC}"
        else
            status_display="${RED}fail${NC}"
        fi
        local mins=$(( _times[idx] / 60 ))
        local secs=$(( _times[idx] % 60 ))
        printf "  %-8s %-12s " "$((idx + 1))" "${_items[$idx]}"
        echo -e "${status_display}     ${mins}m${secs}s"
    done

    printf "  %-8s %-12s %-8s %s\n" "------" "----" "------" "-------"
    local total_mins=$(( batch_elapsed / 60 ))
    local total_secs=$(( batch_elapsed % 60 ))
    local skipped_count=${#_skipped[@]}
    printf "  Passed: %d  Failed: %d  Skipped: %d  Total: %dm%ds\n" "$total_passed" "$total_failed" "$skipped_count" "$total_mins" "$total_secs"

    if [[ $total_failed -gt 0 ]]; then
        echo ""
        echo "  Failed items:"
        for fid in "${!_failed_ids[@]}"; do
            echo "    - $fid: ${_failed_ids[$fid]}"
        done
    fi

    if [[ $skipped_count -gt 0 ]]; then
        echo ""
        echo "  Not attempted (aborted early):"
        for sid in "${_skipped[@]}"; do
            echo "    - $sid"
        done
    fi
    echo ""
}

# Dry-run handler for cmd_run.
# Uses outer-scope locals: auto_mode, auto_scope, specific_id
_run_dry_run() {
    load_config
    cd "$PROJECT_ROOT"

    # Resolve auto_priorities from auto_scope (normally done in setup_sprint_environment)
    local auto_priorities=""
    if [[ "$auto_mode" == "true" ]]; then
        case "$auto_scope" in
            p0)   auto_priorities="must" ;;
            p1)   auto_priorities="must should" ;;
            p2)   auto_priorities="must should could" ;;
            done) auto_priorities="" ;;
        esac
        log_header "aishore run $auto_scope - Dry Run"
        echo "Project: $PROJECT_ROOT"
        echo "Auto-groom: when ready < $AUTO_GROOM_THRESHOLD"
        echo "Circuit breaker: $AUTO_MAX_FAILURES consecutive failures"
    else
        log_header "aishore - Dry Run"
        echo "Project: $PROJECT_ROOT"
    fi
    echo ""

    local item_json
    if ! item_json=$(pick_item "$specific_id"); then
        if [[ -z "$specific_id" ]]; then
            log_warning "No ready items in backlog. Items need readyForSprint: true AND a commander's intent (>=20 chars). Run '.aishore/aishore groom' to prepare items."
        fi
        return 1
    fi

    # Auto mode: check if picked item is within priority scope
    if [[ "$auto_mode" == "true" && -n "$auto_priorities" && -z "$specific_id" ]]; then
        local item_priority
        item_priority=$(jq -r '.priority // "should"' <<< "$item_json")
        if [[ " $auto_priorities " != *" $item_priority "* ]]; then
            log_warning "No items matching $auto_scope scope — next ready item is $item_priority priority"
            return 1
        fi
    fi

    local item_id item_title
    IFS=$'\t' read -r item_id item_title < <(printf '%s\n' "$item_json" | jq -r '[.id, (.title // .description)] | @tsv')

    log_subheader "Selected Item"
    printf '%s\n' "$item_json" | jq .
    echo ""

    # Advisory complexity hints in dry-run
    local hints
    if ! hints=$(check_complexity_hints "$item_id"); then
        log_warning "$item_id may be under-specified — consider adding more steps or scope"
        printf '%b\n' "$hints"
        echo ""
    fi

    # Create temporary sprint.json so build_agent_prompt reads scope from the picked item
    local item_source
    item_source=$(cat "$STATUS_DIR/.item_source" 2>/dev/null || echo "backlog.json")
    local _orig_sprint=""
    [[ -f "$BACKLOG_DIR/sprint.json" ]] && _orig_sprint=$(cat "$BACKLOG_DIR/sprint.json")
    create_sprint "$item_json" "$item_source"

    log_subheader "Developer Prompt"
    build_agent_prompt "developer" "implement"
    echo ""

    # Restore original sprint.json (or remove if there wasn't one)
    if [[ -n "$_orig_sprint" ]]; then
        printf '%s\n' "$_orig_sprint" > "$BACKLOG_DIR/sprint.json"
    else
        rm -f "$BACKLOG_DIR/sprint.json"
    fi

    log_subheader "Validation Command"
    if [[ -n "$VALIDATE_CMD" ]]; then
        printf '%s\n' "$VALIDATE_CMD"
    else
        echo "none configured"
    fi
    echo ""

    log_header "Dry run complete"
    echo "Would pick: $item_id ($item_title)"
    echo "Model: $MODEL_PRIMARY"
    echo "Validation: ${VALIDATE_CMD:-none}"
    return 0
}

refine_item_spec() {
    local item_id="$1"
    local failure_context="$2"

    log_info "Refining spec for $item_id based on failure context"

    local sprint_file="$BACKLOG_DIR/sprint.json"
    [[ ! -f "$sprint_file" ]] && { log_error "No sprint.json for refinement"; return 1; }

    local current_spec
    current_spec=$(jq '.item' "$sprint_file" 2>/dev/null)
    [[ -z "$current_spec" || "$current_spec" == "null" ]] && { log_error "Cannot refine: sprint item spec is empty"; return 1; }

    local refinement_prompt
    refinement_prompt="You are refining a sprint item spec that failed implementation.

## Current Spec
\`\`\`json
$current_spec
\`\`\`

## Failure Context
$failure_context

## Task
Analyze the failures and output an improved spec as a JSON object with exactly these fields:
- \"steps\": array of strings (improved implementation steps)
- \"acceptanceCriteria\": array (strings or {\"text\": \"...\", \"verify\": \"...\"} objects)

Output ONLY the JSON object, no markdown fences, no explanation."

    local refine_output_file
    refine_output_file="$(ensure_tmpdir)/refine_output.txt"

    local -a _refine_cmd=()
    command -v setsid &>/dev/null && _refine_cmd+=(setsid)
    [[ -n "$TIMEOUT_CMD" ]] && _refine_cmd+=("$TIMEOUT_CMD" "${AGENT_TIMEOUT:-3600}")
    _refine_cmd+=(env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT
        claude --model "$MODEL_FAST" --permission-mode acceptEdits
        --allowedTools "Read,Glob,Grep" --print
        -p "$refinement_prompt")

    "${_refine_cmd[@]}" > "$refine_output_file" 2>&1 || {
        local exit_code=$?
        if [[ $exit_code -eq 124 ]]; then
            log_error "Refinement agent timed out after ${AGENT_TIMEOUT:-3600}s"
            return 1
        fi
    }

    local raw_output
    raw_output=$(cat "$refine_output_file" 2>/dev/null || true)
    rm -f "$refine_output_file"

    # Extract JSON from output (handle indentation, markdown fences, surrounding text)
    local json_output=""
    # Strategy: strip markdown fences, then try each line starting with { as potential JSON start
    local stripped
    stripped=$(printf '%s\n' "$raw_output" | sed '/^[[:space:]]*```/d')
    local line_num=0
    while IFS= read -r line; do
        line_num=$((line_num + 1))
        if [[ "$line" =~ ^[[:space:]]*\{ ]]; then
            local candidate
            candidate=$(printf '%s\n' "$stripped" | tail -n +"$line_num" | jq '.' 2>/dev/null | head -500)
            if [[ -n "$candidate" ]] && printf '%s\n' "$candidate" | jq -e '.steps and .acceptanceCriteria' &>/dev/null; then
                json_output="$candidate"
                break
            fi
        fi
    done <<< "$stripped"
    [[ -z "$json_output" ]] && { log_error "Refinement produced no valid JSON"; return 1; }

    # Validate JSON structure
    if ! printf '%s\n' "$json_output" | jq -e '.steps and .acceptanceCriteria' &>/dev/null; then
        log_error "Refinement output missing required fields"
        return 1
    fi

    # Update sprint.json with refined spec
    local tmp_sprint
    tmp_sprint="$(ensure_tmpdir)/sprint_refine.json"
    if jq --argjson refined "$json_output" \
        '.item.steps = $refined.steps | .item.acceptanceCriteria = $refined.acceptanceCriteria' \
        "$sprint_file" > "$tmp_sprint" 2>/dev/null; then
        mv "$tmp_sprint" "$sprint_file"
        log_success "Spec refined for $item_id"
        return 0
    else
        rm -f "$tmp_sprint"
        log_error "Failed to update sprint.json with refined spec"
        return 1
    fi
}

# Pre-flight: run validation command on the baseline before developer touches anything.
# Returns 0 if preflight passes (or no VALIDATE_CMD configured), 1 on failure.
_run_preflight() {
    # Regression suite: run accumulated verify commands from prior sprints
    # This runs even when VALIDATE_CMD is empty — the regression suite IS the eval
    if ! _run_regression_suite; then
        log_error "Pre-flight: regression suite failed — a prior sprint's guarantees are broken"
        return 1
    fi

    [[ -z "$VALIDATE_CMD" ]] && return 0
    log_info "Pre-flight: running validation on baseline"
    local preflight_tmpfile
    preflight_tmpfile="$(ensure_tmpdir)/preflight_output.txt"
    if run_validated_command "$VALIDATE_CMD" "$preflight_tmpfile"; then
        rm -f "$preflight_tmpfile"
        log_success "Pre-flight passed"
        return 0
    fi
    local preflight_output
    preflight_output=$(truncate_output "$preflight_tmpfile")
    rm -f "$preflight_tmpfile"
    log_error "Pre-flight validation failed — baseline is broken"
    log_error "Output (truncated): $preflight_output"
    return 1
}

# Run developer agent for one attempt: build failure context, run fix_cmd on retry,
# invoke developer, run fix_cmd after.
# Uses outer-scope: retry_failure_history, retry_extra_prompt, initial_dev_context, auto_mode, session_failures, attempt, FIX_CMD
# Returns 0 on success, 1 on failure (sets retry_extra_prompt with failure context).
_run_developer_cycle() {
    # Include initial context from caller (e.g., refinement hint) on every attempt
    local dev_extra_prompt=""
    [[ -n "$initial_dev_context" ]] && dev_extra_prompt="$initial_dev_context"

    # Build prior failure context for retries (structured, capped at 2000 chars)
    if [[ $attempt -gt 0 ]]; then
        dev_extra_prompt="${dev_extra_prompt:+${dev_extra_prompt}
}$(_build_prior_failure_context)"
    fi

    # Append session failure patterns for auto mode (last 5 failures only)
    if [[ "$auto_mode" == "true" && ${#session_failures[@]} -gt 0 ]]; then
        local failure_ctx=$'\n## Recent Failure Patterns\nAvoid similar mistakes:'
        local sf_start=$(( ${#session_failures[@]} > 5 ? ${#session_failures[@]} - 5 : 0 ))
        for ((sf_i=sf_start; sf_i<${#session_failures[@]}; sf_i++)); do
            failure_ctx="$failure_ctx"$'\n'"- ${session_failures[$sf_i]}"
        done
        dev_extra_prompt="${dev_extra_prompt}${failure_ctx}"
    fi

    # On retry, run fix_cmd before developer re-attempts
    if [[ $attempt -gt 0 && -n "$FIX_CMD" ]]; then
        log_info "Running fix command before retry: $FIX_CMD"
        if ! bash -c "$FIX_CMD" 2>&1; then
            log_warning "Fix command failed before retry (continuing anyway)"
        fi
    fi

    # Run developer agent
    run_agent "developer" "implement" "$MODEL_PRIMARY" "" "" "$dev_extra_prompt"

    if ! check_result; then
        log_error "Implementation failed"
        local fail_reason=""
        [[ -f "$STATUS_DIR/result.json" ]] && fail_reason=$(jq -r '.reason // .summary // "unknown error"' "$STATUS_DIR/result.json" 2>/dev/null)
        retry_extra_prompt="Previous attempt failed during implementation. Failure reason: ${fail_reason}. Fix the issues and ensure all acceptance criteria pass."
        return 1
    fi

    # Run fix_cmd after developer agent completes (e.g., auto-format, lint --fix)
    if [[ -n "$FIX_CMD" ]]; then
        log_info "Running fix command: $FIX_CMD"
        if ! bash -c "$FIX_CMD" 2>&1; then
            log_warning "Fix command failed (continuing anyway)"
        fi
    fi
    return 0
}

# Run validation cycle: scope check, validation command, AC verification, validator agent.
# Uses outer-scope: retry_extra_prompt, VALIDATE_CMD
# Sets: _validation_failure (short label for _record_sprint_failure)
# Returns 0 if all validations pass, 1 on failure (sets retry_extra_prompt with context).
_run_validation_cycle() {
    _validation_failure=""
    local validate_output=""

    # Run validation command (if configured)
    if [[ -n "$VALIDATE_CMD" ]]; then
        log_info "Running validation: $VALIDATE_CMD"
        local validate_tmpfile
        validate_tmpfile="$(ensure_tmpdir)/validate_output.txt"
        if run_validated_command "$VALIDATE_CMD" "$validate_tmpfile"; then
            validate_output=$(truncate_output "$validate_tmpfile")
            rm -f "$validate_tmpfile"
            log_success "Validation passed"
        else
            validate_output=$(truncate_output "$validate_tmpfile")
            rm -f "$validate_tmpfile"
            log_error "Validation command failed"
            retry_extra_prompt="Previous attempt failed validation command ($VALIDATE_CMD). Validation output:
${validate_output}
Fix the issues and ensure all acceptance criteria pass."
            _validation_failure="Validation failed"
            return 1
        fi
    fi

    # Run AC verification commands (report returned via stdout)
    local ac_report
    ac_report=$(run_ac_verification)
    local ac_rc=$?
    if [[ "$ac_rc" -ne 0 ]]; then
        retry_extra_prompt="Previous attempt failed acceptance criteria verification:
${ac_report}
Fix the issues and ensure all acceptance criteria pass."
        log_error "AC verification failed"
        _validation_failure="AC verification failed"
        return 1
    fi

    # Run validator agent (pass AC report as extra context if available)
    local validator_extra=""
    [[ -n "$ac_report" ]] && validator_extra="
## AC Verification Results
${ac_report}"
    run_agent "validator" "validate" "$MODEL_PRIMARY" "" "" "$validator_extra"
    if ! check_result; then
        log_error "Validation failed"
        local agent_fail_reason=""
        [[ -f "$STATUS_DIR/result.json" ]] && agent_fail_reason=$(jq -r '.reason // .summary // "unknown error"' "$STATUS_DIR/result.json" 2>/dev/null)

        # Try to extract structured per-AC results for targeted retry context
        local ac_targeted_ctx=""
        if [[ -f "$STATUS_DIR/result.json" ]]; then
            local ac_results_json
            ac_results_json=$(jq -c '.ac_results // empty' "$STATUS_DIR/result.json" 2>/dev/null || true)
            if [[ -n "$ac_results_json" && "$ac_results_json" != "null" ]]; then
                ac_targeted_ctx=$(_build_ac_failure_context "$ac_results_json")
            fi
        fi

        # Build rich retry context: per-AC failures (if available) or validator's reason + log tail + validation output
        if [[ -n "$ac_targeted_ctx" ]]; then
            retry_extra_prompt="Previous attempt failed validator review.

${ac_targeted_ctx}"
        else
            retry_extra_prompt="Previous attempt failed validator review.

## Validator Feedback
${agent_fail_reason}"
        fi
        # Append validator log tail for additional context (e.g., AC-by-AC breakdown)
        if [[ -n "$LAST_AGENT_LOG" && -f "$LAST_AGENT_LOG" ]]; then
            local validator_log_tail
            validator_log_tail=$(tail -n 40 "$LAST_AGENT_LOG" 2>/dev/null || true)
            [[ -n "$validator_log_tail" ]] && retry_extra_prompt="${retry_extra_prompt}

## Validator Log (last 40 lines)
${validator_log_tail}"
        fi
        [[ -n "$validate_output" ]] && retry_extra_prompt="${retry_extra_prompt}

## Validation Command Output
${validate_output}"
        retry_extra_prompt="${retry_extra_prompt}

Fix the issues identified above. Address each specific failure point."
        _validation_failure="Validator failed"
        return 1
    fi

    return 0
}

# Failure-reason labels for _record_sprint_failure, keyed by _validation_failure value.
_validation_failure_reason() {
    case "$1" in
        "Scope violation")          echo "Files modified outside declared scope" ;;
        "Validation failed")        echo "Validation command failed" ;;
        "AC verification failed")   echo "Acceptance criteria verification commands failed" ;;
        "Validator failed")         echo "Validator agent rejected implementation" ;;
        *)                          printf '%s\n' "$1" ;;
    esac
}

# Build targeted retry context from structured ac_results JSON.
# Extracts only failed ACs with their issue and file:line references.
# Args: $1 = ac_results JSON array string
# Returns: formatted context string via stdout, or empty if no failures found.
_build_ac_failure_context() {
    local ac_json="$1"
    local failed_count
    failed_count=$(printf '%s' "$ac_json" | jq '[.[] | select(.met == false)] | length' 2>/dev/null || echo "0")
    [[ "$failed_count" -eq 0 ]] && return

    local ctx="## Failed Acceptance Criteria
**Only the ACs below failed — do not re-implement passing ACs.**
"
    local i=0 ac_index issue file line loc
    while IFS= read -r entry; do
        ac_index=$(printf '%s' "$entry" | jq -r '.ac_index // "?"')
        issue=$(printf '%s' "$entry" | jq -r '.issue // "no details"')
        file=$(printf '%s' "$entry" | jq -r '.file // empty' 2>/dev/null || true)
        line=$(printf '%s' "$entry" | jq -r '.line // empty' 2>/dev/null || true)
        loc=""
        if [[ -n "$file" ]]; then
            loc=" ($file"
            [[ -n "$line" ]] && loc="${loc}:${line}"
            loc="${loc})"
        fi
        ctx="${ctx}
- **AC$((ac_index + 1)):**${loc} ${issue}"
        i=$((i + 1))
    done < <(printf '%s' "$ac_json" | jq -c '.[] | select(.met == false)' 2>/dev/null)

    [[ $i -gt 0 ]] && printf '%s\n' "$ctx"
}

# Capture failure context after a failed attempt for retry intelligence.
# Grabs git diff summary + failure reason and appends to retry_failure_history.
# Uses outer-scope: retry_failure_history, retry_extra_prompt, attempt, AISHORE_BASE_BRANCH
_capture_retry_failure() {
    local diff_summary=""
    diff_summary=$(git diff --stat "$AISHORE_BASE_BRANCH" 2>/dev/null | tail -n 20 || true)
    [[ -z "$diff_summary" ]] && diff_summary="(no changes detected)"

    local entry="### Attempt $((attempt + 1))
**Changes:** \`\`\`
${diff_summary}
\`\`\`
**Failure:** ${retry_extra_prompt}"
    retry_failure_history+=("$entry")
}

# Build a structured "Prior failure context" section from retry_failure_history.
# Caps total output at 2000 chars, truncating oldest entries first.
# Returns empty string if history is empty.
_build_prior_failure_context() {
    local count=${#retry_failure_history[@]}
    [[ $count -eq 0 ]] && return

    local header="## Prior Failure Context
**Read each prior attempt below and address the failures before coding.**
"
    local max_body_chars=$(( 2000 - ${#header} ))
    [[ $max_body_chars -lt 100 ]] && max_body_chars=100

    # Build body from newest to oldest, prepending each entry
    local body="" entry_text
    for ((i=count-1; i>=0; i--)); do
        entry_text="${retry_failure_history[$i]}"
        if [[ $(( ${#body} + ${#entry_text} + 2 )) -gt $max_body_chars && -n "$body" ]]; then
            # Would exceed cap — prepend truncation notice and stop
            body="(earlier attempts truncated)
${body}"
            break
        fi
        if [[ -n "$body" ]]; then
            body="${entry_text}
${body}"
        else
            body="$entry_text"
        fi
    done

    printf '%s%s' "$header" "$body"
}

# Developer → validation cmd → validator agent retry loop.
# Uses outer-scope locals: retries, auto_mode, session_failures, sprint_passed,
#   retry_extra_prompt, retry_failure_history, initial_dev_context, item_source, sprint_start, ITEM_ID
_run_retry_loop() {
    local attempt=0
    sprint_passed=false
    initial_dev_context="$retry_extra_prompt"
    retry_extra_prompt=""
    retry_failure_history=()

    if ! _run_preflight; then
        _record_sprint_failure "Pre-flight failed" "Baseline validation failed before developer ran"
        return
    fi

    for ((attempt=0; attempt<=retries; attempt++)); do
        [[ $attempt -gt 0 ]] && log_info "Retry attempt $attempt/$retries"

        if ! _run_developer_cycle; then
            if [[ $attempt -lt $retries ]]; then
                _capture_retry_failure
                log_info "Will retry with failure context"
                continue
            fi
            _record_sprint_failure "Implementation failed" "Implementation failed"
            break
        fi

        if ! _run_validation_cycle; then
            if [[ $attempt -lt $retries ]]; then
                _capture_retry_failure
                log_info "Will retry with failure context"
                continue
            fi
            _record_sprint_failure "$_validation_failure" "$(_validation_failure_reason "$_validation_failure")"
            break
        fi

        sprint_passed=true
        break
    done

    total_attempts=$((attempt + 1))
}

# Push base branch to origin and pull latest. No-op if no remote.
# Args: $1 = branch name
_sync_remote() {
    local branch="$1"
    if git remote get-url origin &>/dev/null; then
        log_info "Syncing with remote"
        git push origin "$branch" 2>/dev/null || \
            log_warning "Failed to push — continuing offline"
        git pull --rebase origin "$branch" 2>/dev/null || \
            log_warning "Failed to pull — continuing with local state"
    fi
}

# Handle post-sprint success: mark complete, safety commit, merge/push.
# Uses outer-scope locals: ITEM_ID, item_source, total_attempts, sprint_start,
#   passed, failed, consecutive_failures, groom_exhausted, no_merge, base_branch,
#   sprint_results, sprint_items, sprint_times, FAILED_IDS, session_lines_added, session_lines_removed
# Returns 1 on merge conflict (caller should break).
_handle_sprint_success() {
    if mark_complete "$ITEM_ID" "$item_source" "$total_attempts"; then
        log_success "Sprint complete: $ITEM_ID"
        COMPLETED_IDS["$ITEM_ID"]=1
        passed=$((passed + 1))
        consecutive_failures=0
        groom_exhausted=false
        sprint_results+=("pass")
        sprint_items+=("$ITEM_ID")
        sprint_times+=("$(( $(date +%s) - sprint_start ))")

        # Save verify commands to regression suite — evals compound across sprints
        _save_regression_entries "$BACKLOG_DIR/sprint.json"

        # Accumulate line stats from the archive entry just written
        local _archive_lines
        _archive_lines=$(tail -1 "$ARCHIVE_DIR/sprints.jsonl" 2>/dev/null || true)
        if [[ -n "$_archive_lines" ]]; then
            local _la _lr
            _la=$(printf '%s' "$_archive_lines" | jq -r '.linesAdded // 0' 2>/dev/null || echo 0)
            _lr=$(printf '%s' "$_archive_lines" | jq -r '.linesRemoved // 0' 2>/dev/null || echo 0)
            session_lines_added=$((session_lines_added + _la))
            session_lines_removed=$((session_lines_removed + _lr))
        fi

        if [[ -n "$NOTIFY_CMD" ]]; then
            bash -c "$NOTIFY_CMD" -- "pass" "$ITEM_ID" 2>/dev/null || log_warning "Notification command failed (exit $?) — sprint outcome unaffected"
        fi

        # Record compact success summary for groom agents
        local _ss_title _ss_ac_count
        _ss_title=$(jq -r '.item.title // ""' "$BACKLOG_DIR/sprint.json" 2>/dev/null || true)
        _ss_ac_count=$(jq -r '.item.acceptanceCriteria | length' "$BACKLOG_DIR/sprint.json" 2>/dev/null || echo 0)
        session_successes+=("$ITEM_ID ($total_attempts attempt(s), $_ss_ac_count AC): $_ss_title")
    else
        log_error "Failed to mark $ITEM_ID complete"
        failed=$((failed + 1))
        FAILED_IDS["$ITEM_ID"]="Archival failed"
        sprint_results+=("fail")
        sprint_items+=("$ITEM_ID")
        sprint_times+=("$(( $(date +%s) - sprint_start ))")
        if [[ -n "$NOTIFY_CMD" ]]; then
            bash -c "$NOTIFY_CMD" -- "fail" "$ITEM_ID" 2>/dev/null || log_warning "Notification command failed (exit $?) — sprint outcome unaffected"
        fi
        # Return to base branch so subsequent sprints branch correctly
        log_warning "Abandoning feature branch $AISHORE_FEATURE_BRANCH due to archival failure"
        git checkout "$base_branch" >/dev/null 2>&1 || true
        git branch -D "$AISHORE_FEATURE_BRANCH" >/dev/null 2>&1 || true
        AISHORE_FEATURE_BRANCH=""
        return 0
    fi

    _safety_commit "$ITEM_ID"

    # Worktree mode: copy result.json back, then remove worktree and restore paths
    # The feature branch (with all commits) is shared via git, so merge works from original dir
    if [[ -n "$AISHORE_WORKTREE_DIR" ]]; then
        # Preserve result.json for PR body / squash message
        [[ -f "$STATUS_DIR/result.json" ]] && cp "$STATUS_DIR/result.json" "$DATA_DIR/status/result.json"
        # Capture archive entry before worktree is destroyed
        local _wt_archive_entry
        _wt_archive_entry=$(tail -1 "$ARCHIVE_DIR/sprints.jsonl" 2>/dev/null || true)
        _cleanup_worktree
        # Append the captured archive entry to the main repo's sprints.jsonl
        if [[ -n "$_wt_archive_entry" ]]; then
            mkdir -p "$ARCHIVE_DIR"
            printf '%s\n' "$_wt_archive_entry" >> "$ARCHIVE_DIR/sprints.jsonl"
        fi
    fi

    # Merge feature branch back to base, push, and pull before next item
    # no-merge: push branch for review, optionally create PR, then return
    if [[ "$no_merge" == "true" ]]; then
        log_info "Branch $AISHORE_FEATURE_BRANCH kept for review"
        if git remote get-url origin &>/dev/null; then
            git push -u origin "$AISHORE_FEATURE_BRANCH" 2>/dev/null || \
                log_warning "Failed to push $AISHORE_FEATURE_BRANCH — push manually"
        fi

        # Create GitHub PR if requested
        if [[ "$create_pr" == "true" ]]; then
            local pr_title pr_body dev_summary
            pr_title="$ITEM_ID: $(jq -r '.item.title // ""' "$BACKLOG_DIR/sprint.json" 2>/dev/null)"
            dev_summary=$(jq -r '.summary // ""' "$STATUS_DIR/result.json" 2>/dev/null || echo "")
            pr_body="## Summary"$'\n\n'"$dev_summary"
            if gh pr create --base "$base_branch" --head "$AISHORE_FEATURE_BRANCH" \
                --title "$pr_title" --body "$pr_body" 2>/dev/null; then
                log_success "GitHub PR created for $ITEM_ID"
            else
                log_warning "Failed to create PR — branch pushed for manual review"
            fi
        fi

        git checkout "$base_branch"
    else
        # Shared merge path: squash or no-ff, branching only on the git merge command
        local merge_summary
        merge_summary=$(jq -r '.summary // ""' "$STATUS_DIR/result.json" 2>/dev/null || echo "")
        merge_summary="${merge_summary:0:500}"
        local merge_msg="merge: $ITEM_ID ${merge_summary:-sprint branch}"

        git checkout "$base_branch"

        if [[ "$MERGE_STRATEGY" == "squash" ]]; then
            log_info "Squash-merging $AISHORE_FEATURE_BRANCH → $base_branch"
            if git merge --squash "$AISHORE_FEATURE_BRANCH"; then
                git commit -m "feat($ITEM_ID): ${merge_summary:-implement sprint item}

Co-Authored-By: Claude <noreply@anthropic.com>"
            else
                log_error "Merge conflict on $AISHORE_FEATURE_BRANCH — resolve manually"
                AISHORE_FEATURE_BRANCH=""
                return 1
            fi
        else
            log_info "Merging $AISHORE_FEATURE_BRANCH → $base_branch"
            if ! git merge --no-ff "$AISHORE_FEATURE_BRANCH" -m "$merge_msg

Co-Authored-By: Claude <noreply@anthropic.com>"; then
                log_error "Merge conflict on $AISHORE_FEATURE_BRANCH — resolve manually"
                AISHORE_FEATURE_BRANCH=""
                return 1
            fi
        fi

        # -D for squash (git can't detect merge), -d for no-ff
        local delete_flag="-d"
        [[ "$MERGE_STRATEGY" == "squash" ]] && delete_flag="-D"
        git branch "$delete_flag" "$AISHORE_FEATURE_BRANCH" 2>/dev/null || true
        log_success "Merged and cleaned up $AISHORE_FEATURE_BRANCH"
        _sync_remote "$base_branch"
    fi
    AISHORE_FEATURE_BRANCH=""
    return 0
}

# Parse command-line arguments for cmd_run.
# Sets outer-scope locals: count, dry_run, specific_id, retries, no_merge,
#   create_pr, auto_mode, auto_scope,
#   max_consecutive_failures
cmd_run_parse_args() {
    parse_opts --positional \
        "bool:dry_run:--dry-run" "bool:no_merge:--no-merge" "bool:create_pr:--pr" \
        "num:max_consecutive_failures:--max-failures" "num:retries:--retries" "num:session_limit:--limit" \
        -- "$@" || return 1
    local _arg
    for _arg in "${_PARSE_REMAINING[@]}"; do
        if [[ "$_arg" =~ ^[0-9]+$ ]]; then
            count="$_arg"
        elif [[ "$_arg" =~ ^(done|p0|p1|p2)$ ]]; then
            auto_scope="$_arg"
            auto_mode=true
        else
            specific_id="$_arg"
            count=1
        fi
    done
}

# Acquire lock, load config, resolve settings, print header,
# initialize tracking variables, and build the item queue.
# Sets outer-scope locals: scope_label, auto_priorities, base_branch,
#   passed, failed, batch_start, consecutive_failures, groom_exhausted,
#   sprint_results, sprint_items, sprint_times, session_failures, queued_ids, skipped_ids
setup_sprint_environment() {
    acquire_lock
    load_config
    cd "$PROJECT_ROOT"

    # Apply timeout_minutes: config/env > default (0 = no override)
    if [[ "${TIMEOUT_MINUTES:-0}" -gt 0 ]]; then
        AGENT_TIMEOUT=$((TIMEOUT_MINUTES * 60))
        log_info "Agent timeout set to ${TIMEOUT_MINUTES} minutes (${AGENT_TIMEOUT}s)"
    fi

    # Config-driven PR creation (--pr flag overrides)
    if [[ "$create_pr" != "true" && "$CREATE_PR" == "true" ]]; then
        create_pr=true
    fi

    # Config-driven retries (--retries flag overrides)
    if [[ "$retries" -eq 0 && "${SESSION_RETRIES:-0}" -gt 0 ]]; then
        retries="$SESSION_RETRIES"
    fi

    # Config-driven session_limit (--limit flag overrides)
    if [[ -z "$session_limit" && -n "$SESSION_LIMIT" ]]; then
        session_limit="$SESSION_LIMIT"
    fi

    # --pr implies --no-merge
    if [[ "$create_pr" == "true" ]]; then
        no_merge=true
        # Fall back to no-merge if gh is not available
        if ! command -v gh &>/dev/null; then
            log_warning "gh CLI not found — falling back to --no-merge (no PR will be created)"
            create_pr=false
        fi
    fi

    # Resolve max_consecutive_failures: flag > config > default
    [[ -z "$max_consecutive_failures" ]] && max_consecutive_failures="$AUTO_MAX_FAILURES"

    # Auto mode setup
    scope_label=""
    if [[ "$auto_mode" == "true" ]]; then
        count=9999
        case "$auto_scope" in
            p0)   auto_priorities="must";              scope_label="P0 (must)" ;;
            p1)   auto_priorities="must should";       scope_label="P0+P1 (must + should)" ;;
            p2)   auto_priorities="must should could"; scope_label="P0–P2 (must + should + could)" ;;
            done) auto_priorities="";                  scope_label="all items" ;;
        esac
        log_header "aishore run $auto_scope"
    else
        log_header "aishore"
    fi
    echo "Project: $PROJECT_ROOT"
    if [[ "$auto_mode" == "true" ]]; then
        echo "Scope: $scope_label"
        echo "Circuit breaker: $max_consecutive_failures consecutive failures"
    elif [[ -n "$specific_id" ]]; then
        echo "Item: $specific_id"
    else
        echo "Sprints: $count"
    fi
    [[ -n "$session_limit" ]] && echo "Session limit: $session_limit items"
    [[ "$no_merge" == "true" ]] && echo "Merge: disabled (branches kept for review)"
    [[ "$retries" -gt 0 ]] && echo "Retries: $retries"
    echo ""

    base_branch=$(git rev-parse --abbrev-ref HEAD)
    AISHORE_BASE_BRANCH="$base_branch"

    passed=0
    failed=0
    batch_start=$(date +%s)
    sprint_results=()
    sprint_items=()
    sprint_times=()
    consecutive_failures=0
    groom_exhausted=false
    session_failures=()
    queued_ids=()
    skipped_ids=()
    session_lines_added=0
    session_lines_removed=0

    # Pre-build ordered list of all items that could be attempted in this batch
    if [[ -n "$specific_id" ]]; then
        queued_ids=("$specific_id")
    else
        mapfile -t queued_ids < <(list_pickable_ids "" "$auto_priorities")
    fi

    # Auto mode: log queued item count with per-priority breakdown
    if [[ "$auto_mode" == "true" && -z "$specific_id" ]]; then
        local total=${#queued_ids[@]}
        if [[ "$total" -eq 0 ]]; then
            log_info "No items to run"
            return 0
        fi

        # Count items per priority tier from backlogs
        local ids_json n_must=0 n_should=0 n_could=0
        ids_json=$(printf '%s\n' "${queued_ids[@]}" | jq -R . | jq -s .)
        local _prio_counts
        _prio_counts="$(ensure_tmpdir)/prio_counts.txt"
        : > "$_prio_counts"
        _count_prios_one() {
            local f="$1"
            [[ -f "$BACKLOG_DIR/$f" ]] || return 0
            jq -r --argjson ids "$ids_json" '
                [.items[] | select(.id as $id | $ids | index($id) != null)] |
                group_by(.priority // "should") |
                .[] | "\(.[0].priority // "should") \(length)"
            ' "$BACKLOG_DIR/$f" 2>/dev/null >> "$_prio_counts" || true
        }
        map_backlog_files _count_prios_one

        local prio cnt
        while read -r prio cnt; do
            [[ -z "$prio" ]] && continue
            case "$prio" in
                must)   n_must=$((n_must + cnt)) ;;
                should) n_should=$((n_should + cnt)) ;;
                could)  n_could=$((n_could + cnt)) ;;
            esac
        done < "$_prio_counts"

        # Build breakdown string, omitting tiers with zero count
        local parts=()
        [[ "$n_must" -gt 0 ]] && parts+=("must=$n_must")
        [[ "$n_should" -gt 0 ]] && parts+=("should=$n_should")
        [[ "$n_could" -gt 0 ]] && parts+=("could=$n_could")

        if [[ ${#parts[@]} -gt 0 ]]; then
            local breakdown
            breakdown=$(IFS=' '; echo "${parts[*]}")
            log_info "Queuing $total item(s): $breakdown"
        else
            log_info "Queuing $total item(s)"
        fi
    fi
}

# Count total ready items across all backlogs
# Build combined failure+success feedback for groom agents.
# Reads outer-scope: session_failures, session_successes arrays.
# Outputs the combined feedback string to stdout.
_build_groom_feedback() {
    local feedback=""
    if [[ ${#session_failures[@]} -gt 0 ]]; then
        feedback="## Recent Sprint Failures
Items below failed during implementation or validation. Use these patterns to write better specs — clearer steps, more specific AC, tighter scope.
"
        local start=$(( ${#session_failures[@]} > 5 ? ${#session_failures[@]} - 5 : 0 ))
        local idx
        for ((idx=start; idx<${#session_failures[@]}; idx++)); do
            feedback="${feedback}
- ${session_failures[$idx]}"
        done
    fi
    local success_fb=""
    if [[ ${#session_successes[@]} -gt 0 ]]; then
        success_fb="## Recent Sprint Successes
These items passed on implementation. Learn from their spec patterns — clear intent, right-sized steps, testable AC.
"
        local start=$(( ${#session_successes[@]} > 5 ? ${#session_successes[@]} - 5 : 0 ))
        local idx
        for ((idx=start; idx<${#session_successes[@]}; idx++)); do
            success_fb="${success_fb}
- ${session_successes[$idx]}"
        done
    fi
    if [[ -f "$ARCHIVE_DIR/sprints.jsonl" ]]; then
        local specs
        specs=$(tail -10 "$ARCHIVE_DIR/sprints.jsonl" 2>/dev/null | jq -r \
            'select(.status == "complete") | "- \(.itemId) (\(.attempts) attempt(s)): \(.title // .itemId)"' 2>/dev/null || true)
        if [[ -n "$specs" ]]; then
            success_fb="${success_fb:+${success_fb}

}## Specs That Worked
Recent completed items — these spec structures produced passing sprints. Emulate their patterns.
${specs}"
        fi
    fi
    [[ -n "$feedback" ]] && printf '%s' "$feedback"
    if [[ -n "$success_fb" ]]; then
        [[ -n "$feedback" ]] && printf '\n\n'
        printf '%s' "$success_fb"
    fi
}

_count_total_ready() {
    sum_backlog_count count_ready_items
}

# Record a sprint failure: update counters, mark item, store context, notify
# Uses outer-scope locals from cmd_run and setup_sprint_environment.
_record_sprint_failure() {
    local reason="$1" detail="$2"
    failed=$((failed + 1))
    consecutive_failures=$((consecutive_failures + 1))
    FAILED_IDS["$ITEM_ID"]="$reason"
    session_failures+=("$ITEM_ID: $reason")
    mark_item_failed "$ITEM_ID" "$detail" "$item_source"
    sprint_results+=("fail")
    sprint_items+=("$ITEM_ID")
    sprint_times+=("$(( $(date +%s) - sprint_start ))")

    # Store failure context for later diagnosis
    _store_failure_context "$ITEM_ID" "$reason" "$detail"

    if [[ -n "$NOTIFY_CMD" ]]; then
        bash -c "$NOTIFY_CMD" -- "fail" "$ITEM_ID" 2>/dev/null || log_warning "Notification command failed (exit $?) — sprint outcome unaffected"
    fi
    handle_sprint_failure
}


# Execute the core pick-implement-validate-merge cycle.
# Uses and modifies outer-scope locals from cmd_run and setup_sprint_environment.
run_sprint_loop() {
    for ((i=1; i<=count; i++)); do
        if [[ "$auto_mode" == "true" && "$consecutive_failures" -ge "$max_consecutive_failures" ]]; then
            log_error "Circuit breaker: $consecutive_failures consecutive failures — stopping"
            break
        fi

        if [[ "$auto_mode" == "true" ]]; then
            # Session progress line
            local elapsed_secs elapsed_min progress_count
            elapsed_secs=$(( $(date +%s) - batch_start ))
            elapsed_min=$(( elapsed_secs / 60 ))
            if [[ ${#queued_ids[@]} -gt 0 ]]; then
                local display_total="${#queued_ids[@]}"
                if [[ -n "$session_limit" && "$session_limit" -lt "$display_total" ]]; then
                    display_total="$session_limit"
                fi
                progress_count="$passed/$display_total complete"
            else
                progress_count="$passed complete"
            fi
            log_info "Sprint session: $progress_count | $failed failed | ${elapsed_min}m elapsed"
            log_subheader "Sprint $i (passed: $passed, failed: $failed)"
        else
            [[ $count -gt 1 ]] && log_subheader "Sprint $i/$count"
        fi
        local sprint_start
        sprint_start=$(date +%s)

        # Auto mode: auto-groom when ready items are low
        if [[ "$auto_mode" == "true" && "$groom_exhausted" != "true" ]]; then
            local total_ready
            total_ready=$(_count_total_ready)
            if [[ "$total_ready" -lt "$AUTO_GROOM_THRESHOLD" ]]; then
                log_info "Auto: ready buffer low ($total_ready < $AUTO_GROOM_THRESHOLD) — grooming"
                # Auto-clean done items so groom agents see lean backlogs
                _load_module cmd-clean; cmd_clean 2>/dev/null || true
                _load_module cmd-groom
                local -a groom_context
                # shellcheck disable=SC2034  # used via nameref in run_agent
                mapfile -t groom_context < <(_build_groom_context)
                local groom_combined_feedback
                groom_combined_feedback=$(_build_groom_feedback)
                # Snapshot for groom limit enforcement
                local auto_groom_snap
                auto_groom_snap=$(mktemp -d)
                snapshot_backlog_files "$auto_groom_snap"
                # Architect runs first — detects fragment risk and creates scaffolding items
                # before tech-lead/product-owner groom features that depend on the skeleton
                GROOM_MONITOR=true run_agent "architect" "groom" "$MODEL_FAST" groom_context "" "$groom_combined_feedback" || true
                GROOM_MONITOR=
                check_result || log_warning "Architect groom did not pass — continuing"
                GROOM_MONITOR=true run_agent "tech-lead" "groom" "$MODEL_FAST" groom_context "" "$groom_combined_feedback" || true
                GROOM_MONITOR=
                check_result || log_warning "Tech-lead groom did not pass — continuing"
                GROOM_MONITOR=true run_agent "product-owner" "groom" "$MODEL_FAST" groom_context "" "$groom_combined_feedback" || true
                GROOM_MONITOR=
                check_result || log_warning "Product-owner groom did not pass — continuing"
                # Protect existing items from groomer rewrites, then enforce limits
                protect_items_from_groom "$auto_groom_snap"
                local auto_groom_counts auto_groom_added auto_groom_skipped
                auto_groom_counts=$(enforce_groom_limits "$auto_groom_snap")
                read -r auto_groom_added auto_groom_skipped <<< "$auto_groom_counts"
                rm -rf "$auto_groom_snap"
                if [[ "$auto_groom_skipped" -gt 0 ]]; then
                    log_info "Auto-groom: $auto_groom_added item(s) added, $auto_groom_skipped skipped (limits: max=$GROOM_MAX_ITEMS, min_priority=$GROOM_MIN_PRIORITY)"
                fi
                if [[ "$(_count_total_ready)" -le "$total_ready" ]]; then
                    log_warning "Groom did not produce new ready items — pausing auto-groom"
                    groom_exhausted=true
                fi
                # Refresh queued_ids so progress denominator reflects newly groomed items
                local -a _skip_for_refresh=()
                for _k in "${!FAILED_IDS[@]}"; do _skip_for_refresh+=("$_k"); done
                for _k in "${!COMPLETED_IDS[@]}"; do _skip_for_refresh+=("$_k"); done
                local _refresh_skip
                _refresh_skip=$(IFS=,; printf '%s' "${_skip_for_refresh[*]}")
                local -a _updated_ids
                mapfile -t _updated_ids < <(list_pickable_ids "$_refresh_skip" "$auto_priorities")
                local _uid
                for _uid in "${_updated_ids[@]}"; do
                    local _already_queued=false
                    local _qid
                    for _qid in "${queued_ids[@]}"; do
                        if [[ "$_qid" == "$_uid" ]]; then
                            _already_queued=true
                            break
                        fi
                    done
                    if [[ "$_already_queued" == "false" ]]; then
                        queued_ids+=("$_uid")
                    fi
                done
            fi
        fi

        # Build exclusion list from failed and already-completed items
        local -a _skip_keys=()
        local _k
        for _k in "${!FAILED_IDS[@]}"; do _skip_keys+=("$_k"); done
        for _k in "${!COMPLETED_IDS[@]}"; do _skip_keys+=("$_k"); done
        local skip_list
        skip_list=$(IFS=,; printf '%s' "${_skip_keys[*]}")

        local item_json
        if ! item_json=$(pick_item "$specific_id" "$skip_list"); then
            if [[ -n "$specific_id" ]]; then
                : # resolve_backlog_file already printed the error
            elif [[ "$auto_mode" == "true" ]]; then
                log_success "No more ready items — backlog drained"
            else
                log_warning "No ready items in backlog. Items need readyForSprint: true AND a commander's intent (>=20 chars). Run '.aishore/aishore groom' to prepare items."
            fi
            break
        fi

        # Auto mode: check if picked item is within priority scope
        if [[ "$auto_mode" == "true" && -n "$auto_priorities" ]]; then
            local item_priority
            item_priority=$(jq -r '.priority // "should"' <<< "$item_json")
            if [[ " $auto_priorities " != *" $item_priority "* ]]; then
                log_success "All $auto_scope items complete — remaining items are lower priority"
                break
            fi
        fi

        local item_source
        item_source=$(get_item_source)
        [[ -z "$item_source" ]] && { log_error "Failed to determine item source. Ensure the item exists in backlog/backlog.json or backlog/bugs.json and retry"; break; }

        create_sprint "$item_json" "$item_source"
        save_backlog_snapshot

        # Advisory complexity hints (does not block sprint)
        local hints
        if ! hints=$(check_complexity_hints "$ITEM_ID"); then
            log_warning "$ITEM_ID may be under-specified — consider adding more steps or scope"
            printf '%b\n' "$hints"
        fi

        # Create feature branch
        local branch_name="aishore/${ITEM_ID}"
        branch_name=$(printf '%s\n' "$branch_name" | sed 's/[^a-zA-Z0-9/_-]/-/g')
        log_info "Creating branch: $branch_name"

        # Worktree isolation: create a separate working directory for the sprint
        local wt_dir
        wt_dir=$(mktemp -d "${TMPDIR:-/tmp}/aishore-wt-XXXXXX")
        rmdir "$wt_dir"  # git worktree add needs a non-existing path
        git branch -D "$branch_name" 2>/dev/null || true
        git worktree add "$wt_dir" -b "$branch_name"
        AISHORE_WORKTREE_DIR="$wt_dir"
        AISHORE_FEATURE_BRANCH="$branch_name"

        # Redirect paths into the worktree so agents and polling work there
        STATUS_DIR="$wt_dir/.aishore/data/status"
        LOGS_DIR="$wt_dir/.aishore/data/logs"
        BACKLOG_DIR="$wt_dir/backlog"
        ARCHIVE_DIR="$BACKLOG_DIR/archive"
        mkdir -p "$STATUS_DIR" "$LOGS_DIR" "$ARCHIVE_DIR"

        # Copy current sprint.json into worktree backlog (create_sprint wrote to original)
        cp "$PROJECT_ROOT/backlog/sprint.json" "$BACKLOG_DIR/sprint.json"

        cd "$wt_dir"
        log_info "Worktree created: $wt_dir"

        # Developer → validation → validator (with retries)
        local sprint_passed=false
        local retry_extra_prompt=""
        local initial_dev_context=""
        local total_attempts=1
        _run_retry_loop

        if [[ "$sprint_passed" != "true" ]]; then
            # Refinement: always refine spec and try once more before final failure
            log_info "Attempting spec refinement after exhausting retries"
            local failure_ctx=""
            for sf in "${session_failures[@]}"; do
                failure_ctx="${failure_ctx}${sf}"$'\n'
            done
            [[ -n "$retry_extra_prompt" ]] && failure_ctx="${failure_ctx}Last failure context: ${retry_extra_prompt}"

            if refine_item_spec "$ITEM_ID" "$failure_ctx"; then
                log_info "Running one more developer → validate → validator cycle with refined spec"
                # Reset failure tracking for this single refinement attempt
                local saved_retries=$retries
                local prior_attempts=$total_attempts
                retries=0
                retry_extra_prompt="This is a REFINED spec after previous failures. Pay close attention to the updated steps and acceptance criteria."
                sprint_passed=false
                _run_retry_loop
                retries=$saved_retries
                total_attempts=$((prior_attempts + total_attempts))
            else
                log_warning "Spec refinement failed — cannot retry"
            fi

            if [[ "$sprint_passed" != "true" ]]; then
                [[ "$auto_mode" == "true" ]] && log_info "Progress: $passed passed, $failed failed, $(_count_total_ready) remaining ready"
                continue
            fi
        fi

        # Success: mark complete, commit, merge/push
        if ! _handle_sprint_success; then
            # Merge conflict — compute items queued but not attempted
            for _qid in "${queued_ids[@]}"; do
                local _was_started=false
                for _sid in "${sprint_items[@]}"; do
                    [[ "$_qid" == "$_sid" ]] && { _was_started=true; break; }
                done
                [[ "$_was_started" == "false" ]] && skipped_ids+=("$_qid")
            done
            if [[ ${#skipped_ids[@]} -gt 0 ]]; then
                log_warning "Items queued but not attempted due to merge conflict:"
                for _qid in "${skipped_ids[@]}"; do
                    echo "    - $_qid"
                done
            fi
            break
        fi

        [[ "$auto_mode" == "true" ]] && log_info "Progress: $passed passed, $failed failed, $(_count_total_ready) remaining ready"

        # Session limit: exit cleanly after N successful items
        if [[ -n "$session_limit" && "$passed" -ge "$session_limit" ]]; then
            log_success "Session limit reached: $passed items completed"
            break
        fi
    done
}

# Print end-of-session summary table with counts, duration, and lines changed.
# Uses outer-scope locals from cmd_run and setup_sprint_environment.
print_session_summary_table() {
    local batch_elapsed=$(( $(date +%s) - batch_start ))
    local total_mins=$(( batch_elapsed / 60 ))
    local total_secs=$(( batch_elapsed % 60 ))
    local attempted=$((passed + failed))

    echo ""
    echo -e "${CYAN}--------------------------------------${NC}"
    echo -e "${CYAN}  Session Summary${NC}"
    echo -e "${CYAN}--------------------------------------${NC}"
    echo "  Items attempted   $(printf '%14s' "$attempted")"
    echo "  Items passed      $(printf '%14s' "$passed")"
    echo "  Items failed      $(printf '%14s' "$failed")"
    echo "  Total duration    $(printf '%14s' "${total_mins}m ${total_secs}s")"
    echo "  Lines added       $(printf '%14s' "+${session_lines_added}")"
    echo "  Lines removed     $(printf '%14s' "-${session_lines_removed}")"
    echo -e "${CYAN}--------------------------------------${NC}"
    echo ""
}

# Print batch summary, offer architecture review, and print final status.
# Uses outer-scope locals from cmd_run and setup_sprint_environment.
print_sprint_summary() {
    # Print batch summary for auto mode or multi-sprint runs
    if [[ "$auto_mode" == "true" || $count -gt 1 ]]; then
        print_batch_summary "$batch_start" sprint_results sprint_items sprint_times FAILED_IDS skipped_ids
    fi

    # Print end-of-session summary table
    if [[ $((passed + failed)) -gt 0 ]]; then
        print_session_summary_table
    fi

    # Zero-items-processed warning: when auto mode processes nothing but backlog has items
    if [[ "$auto_mode" == "true" && $passed -eq 0 && $failed -eq 0 ]]; then
        local total_backlog_items
        total_backlog_items=$(sum_backlog_count count_items)
        if [[ "$total_backlog_items" -gt 0 ]]; then
            log_warning "Session ended: 0 items processed. $total_backlog_items item(s) in backlog were not ready — run '.aishore/aishore backlog check --all' to audit readiness."
        fi
    fi

    if [[ "$auto_mode" == "true" ]]; then
        if [[ $failed -eq 0 && $passed -gt 0 ]]; then
            log_header "Mission complete: $passed items done"
            send_session_notification "Sprint session complete: $passed items done"
        elif [[ "$consecutive_failures" -ge "$max_consecutive_failures" ]]; then
            log_header "Mission aborted: circuit breaker ($passed passed, $failed failed)"
            send_session_notification "Sprint session stopped: $consecutive_failures consecutive failures ($passed passed, $failed failed)"
        else
            log_header "Mission ended: $passed passed, $failed failed"
            send_session_notification "Sprint session ended: $passed passed, $failed failed"
        fi
    else
        log_header "Results: $passed passed, $failed failed"
    fi
    if [[ $failed -gt 0 || $passed -eq 0 ]]; then
        log_error "Sprint completed with failures ($passed passed, $failed failed)"
        return 1
    fi
    return 0
}

cmd_run() {
    require_tool jq
    require_tool git

    local count=1 dry_run=false specific_id="" retries=0
    local no_merge=false create_pr=false
    local auto_mode=false auto_scope="" auto_priorities=""
    local max_consecutive_failures="" session_limit=""

    cmd_run_parse_args "$@" || return $?

    # Validate --limit early (before dry-run branch)
    if [[ -n "$session_limit" ]]; then
        if [[ "$session_limit" -le 0 ]] 2>/dev/null; then
            log_error "limit must be a positive integer (got: $session_limit)"
            return 1
        fi
    fi

    if [[ "$dry_run" == "true" ]]; then
        _run_dry_run
        return $?
    fi

    local scope_label="" base_branch
    local session_lines_added=0 session_lines_removed=0
    local passed=0 failed=0
    declare -A FAILED_IDS
    declare -A COMPLETED_IDS
    local batch_start sprint_results=() sprint_items=() sprint_times=()
    local consecutive_failures=0 groom_exhausted=false
    local -a session_failures=() session_successes=() queued_ids=() skipped_ids=()

    setup_sprint_environment || return $?

    run_sprint_loop

    print_sprint_summary
}

