mark_item_failed() { dal_mark_failed "$@"; }

# ============================================================================
# SPRINT STATE MACHINE
# ============================================================================
# Explicit state tracking for crash recovery. State file lives in the original
# project root (DATA_DIR), not in the worktree, so it survives worktree cleanup.

_SM_STATE_FILE=""

_sm_init() {
    _SM_STATE_FILE="$DATA_DIR/status/sprint-state.json"
}

_sm_transition() {
    local new_state="$1"
    [[ -z "$_SM_STATE_FILE" ]] && _sm_init
    local now
    now=$(portable_date_iso)
    local tmp
    tmp="$(ensure_tmpdir)/sm_transition.json"
    if [[ -f "$_SM_STATE_FILE" ]]; then
        jq --arg state "$new_state" --arg ts "$now" --argjson pid "$$" \
            '.state = $state | .lastTransition = $ts | .pid = $pid' \
            "$_SM_STATE_FILE" > "$tmp" 2>/dev/null || {
            # If existing file is corrupt, create fresh
            printf '{"state":"%s","lastTransition":"%s","pid":%d}\n' "$new_state" "$now" "$$" > "$tmp"
        }
    else
        jq -n --arg state "$new_state" --arg ts "$now" --argjson pid "$$" \
            '{state: $state, lastTransition: $ts, pid: $pid}' > "$tmp"
    fi
    mv "$tmp" "$_SM_STATE_FILE"
}

_sm_set_sprint_context() {
    [[ -z "$_SM_STATE_FILE" ]] && _sm_init
    [[ -f "$_SM_STATE_FILE" ]] || return 0
    local tmp
    tmp="$(ensure_tmpdir)/sm_context.json"
    jq --arg iid "${1:-}" --arg sid "${2:-}" --arg wt "${3:-}" --arg br "${4:-}" --arg base "${5:-}" --argjson attempt "${6:-1}" \
        '. + {itemId: $iid, sprintId: $sid, worktreeDir: $wt, featureBranch: $br, baseBranch: $base, attempt: $attempt}' \
        "$_SM_STATE_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$_SM_STATE_FILE"
}

_sm_get_state() {
    [[ -z "$_SM_STATE_FILE" ]] && _sm_init
    if [[ -f "$_SM_STATE_FILE" ]]; then
        jq -r '.state // "idle"' "$_SM_STATE_FILE" 2>/dev/null || echo "idle"
    else
        echo "idle"
    fi
}

_sm_clear() {
    [[ -z "$_SM_STATE_FILE" ]] && _sm_init
    rm -f "$_SM_STATE_FILE"
}

# Crash recovery: called at the start of every cmd_run.
# If a previous sprint was interrupted, clean up orphaned resources.
_sm_recover_on_startup() {
    _sm_init
    [[ -f "$_SM_STATE_FILE" ]] || return 0

    local state
    state=$(_sm_get_state)
    [[ "$state" == "idle" ]] && { _sm_clear; return 0; }

    # Check if the owning process is still running
    local owner_pid
    owner_pid=$(jq -r '.pid // 0' "$_SM_STATE_FILE" 2>/dev/null || echo 0)
    if [[ "$owner_pid" -gt 0 ]] && kill -0 "$owner_pid" 2>/dev/null; then
        # Another process owns this sprint — lock will handle the conflict
        return 0
    fi

    # Previous process crashed — recover
    log_warning "Recovering from crashed sprint (state: $state)"

    local wt_dir branch_name item_id item_source
    wt_dir=$(jq -r '.worktreeDir // ""' "$_SM_STATE_FILE" 2>/dev/null || true)
    branch_name=$(jq -r '.featureBranch // ""' "$_SM_STATE_FILE" 2>/dev/null || true)
    item_id=$(jq -r '.itemId // ""' "$_SM_STATE_FILE" 2>/dev/null || true)

    # Clean up worktree
    if [[ -n "$wt_dir" && -d "$wt_dir" ]]; then
        log_info "Removing orphaned worktree: $wt_dir"
        _remove_worktree "$wt_dir" 2>/dev/null || true
    fi

    # Clean up branch
    if [[ -n "$branch_name" ]]; then
        git branch -D "$branch_name" 2>/dev/null || true
    fi

    # Mark item as failed
    if [[ -n "$item_id" ]]; then
        # Resolve the item's source backlog from the original project backlog
        local source
        source=$(dal_resolve_file "$item_id" 2>/dev/null || true)
        if [[ -n "$source" ]]; then
            dal_mark_failed "$item_id" "CRASH: recovered from state '$state'" "$source"
            log_warning "Item $item_id marked as failed (crash recovery)"
        fi
    fi

    _sm_clear
    log_success "Crash recovery complete"
}

_ctx_enter_worktree() {
    local wt_dir="$1"
    STATUS_DIR="$wt_dir/.aishore/data/status"
    LOGS_DIR="$wt_dir/.aishore/data/logs"
    BACKLOG_DIR="$wt_dir/backlog"
    ARCHIVE_DIR="$BACKLOG_DIR/archive"
    CTX_IN_WORKTREE=true
    mkdir -p "$STATUS_DIR" "$LOGS_DIR" "$ARCHIVE_DIR"
}

_ctx_exit_worktree() {
    STATUS_DIR="$DATA_DIR/status"
    LOGS_DIR="$DATA_DIR/logs"
    BACKLOG_DIR="$PROJECT_ROOT/backlog"
    ARCHIVE_DIR="$BACKLOG_DIR/archive"
    CTX_IN_WORKTREE=false
}

_cleanup_worktree() {
    # Remove worktree and restore paths to original project root
    if [[ -n "$AISHORE_WORKTREE_DIR" ]]; then
        _remove_worktree "$AISHORE_WORKTREE_DIR"
        AISHORE_WORKTREE_DIR=""
        _ctx_exit_worktree
    fi
}

_store_failure_context() {
    local item_id="$1" reason="$2" detail="$3"
    local failure_file="$STATUS_DIR/last-failure.json"
    local result_content="{}"
    [[ -f "$STATUS_DIR/result.json" ]] && result_content=$(cat "$STATUS_DIR/result.json" 2>/dev/null || echo "{}")
    local agent_log_path="${LAST_AGENT_LOG:-}"
    local agent_stderr=""
    if [[ -n "$agent_log_path" && -f "$agent_log_path" ]]; then
        # Capture last 50 lines for stored context (more than the 20 shown inline)
        agent_stderr=$(tail -n 50 "$agent_log_path" 2>/dev/null || true)
    fi
    jq -n \
        --arg item_id "$item_id" \
        --arg reason "$reason" \
        --arg detail "$detail" \
        --arg timestamp "$(portable_date_iso)" \
        --arg agent_log "$agent_log_path" \
        --argjson result "$result_content" \
        --arg log_tail "$agent_stderr" \
        '{itemId: $item_id, reason: $reason, detail: $detail, timestamp: $timestamp, agentLog: $agent_log, result: $result, logTail: $log_tail}' \
        > "$failure_file" 2>/dev/null || true
}

handle_sprint_failure() {
    log_warning "Resetting working tree after sprint failure"

    if [[ -n "$AISHORE_WORKTREE_DIR" ]]; then
        # Preserve diagnostics from worktree before it's destroyed
        local _base_status="$DATA_DIR/status"
        local _base_logs="$DATA_DIR/logs"
        mkdir -p "$_base_status" "$_base_logs"
        if [[ -f "$STATUS_DIR/result.json" ]]; then
            cp "$STATUS_DIR/result.json" "$_base_status/result.json" 2>/dev/null || true
        fi
        if [[ -n "$LAST_AGENT_LOG" && -f "$LAST_AGENT_LOG" ]]; then
            local _base_log="$_base_logs/$(basename "$LAST_AGENT_LOG")"
            cp "$LAST_AGENT_LOG" "$_base_log" 2>/dev/null || true
            LAST_AGENT_LOG="$_base_log"
        fi
        # Worktree mode: remove worktree and delete the branch
        local fb="$AISHORE_FEATURE_BRANCH"
        AISHORE_FEATURE_BRANCH=""
        _cleanup_worktree
        if [[ -n "$fb" ]]; then git branch -D "$fb" 2>/dev/null || true; fi
    elif [[ -n "$AISHORE_FEATURE_BRANCH" && -n "$AISHORE_BASE_BRANCH" ]]; then
        # Fallback: switch back to base and delete the branch
        # (base branch still has backlog state from earlier successful sprints)
        local fb="$AISHORE_FEATURE_BRANCH"
        AISHORE_FEATURE_BRANCH=""
        git checkout "$AISHORE_BASE_BRANCH" 2>/dev/null || true
        git branch -D "$fb" 2>/dev/null || true
    else
        # Fallback for non-branching context
        local snapshot_dir="$STATUS_DIR/backlog-snapshot"
        local has_snapshot=false
        [[ -d "$snapshot_dir" ]] && has_snapshot=true

        git reset HEAD -- . 2>/dev/null || true
        git checkout -- . 2>/dev/null || true
        git clean -fd -e '.aishore' 2>/dev/null || true

        if [[ "$has_snapshot" == true ]]; then
            local _rbf; for _rbf in "${BACKLOG_FILES[@]}"; do [[ -f "$STATUS_DIR/backlog-snapshot/$_rbf" ]] && cp "$STATUS_DIR/backlog-snapshot/$_rbf" "$BACKLOG_DIR/$_rbf"; done
        fi
    fi
    reset_sprint
}

