# Protect .aishore/ tool files from agent modification during sprints.
# Makes tool files read-only while leaving data/, config.yaml writable.
_lock_tool_files() {
    local f
    for f in "$AISHORE_ROOT/aishore" "$AISHORE_ROOT/VERSION" "$AISHORE_ROOT/checksums.sha256"; do
        [[ -f "$f" ]] && chmod a-w "$f" 2>/dev/null || true
    done
    for f in "$AGENTS_DIR"/*.md "$AISHORE_ROOT"/lib/*.sh "$AISHORE_ROOT"/templates/*; do
        [[ -f "$f" ]] && chmod a-w "$f" 2>/dev/null || true
    done
}

# Restore write permissions on .aishore/ tool files.
_unlock_tool_files() {
    local f
    for f in "$AISHORE_ROOT/aishore" "$AISHORE_ROOT/VERSION" "$AISHORE_ROOT/checksums.sha256"; do
        [[ -f "$f" ]] && chmod u+w "$f" 2>/dev/null || true
    done
    for f in "$AGENTS_DIR"/*.md "$AISHORE_ROOT"/lib/*.sh "$AISHORE_ROOT"/templates/*; do
        [[ -f "$f" ]] && chmod u+w "$f" 2>/dev/null || true
    done
}

acquire_lock() {
    local lockdir="$STATUS_DIR/.aishore.lock"
    mkdir -p "$STATUS_DIR" 2>/dev/null || true

    # Migrate from old flock-based flat file
    [[ -f "$lockdir" ]] && rm -f "$lockdir"

    local attempt
    for (( attempt = 0; attempt < 2; attempt++ )); do
        if mkdir "$lockdir" 2>/dev/null; then
            # Atomic PID write: write to temp file, then mv (atomic on POSIX).
            # If killed between mkdir and mv, lock dir has no pid → stale detection handles it.
            local tmp_pid
            tmp_pid=$(mktemp "$lockdir/pid.XXXXXX" 2>/dev/null) || {
                rm -rf "$lockdir"
                log_error "Failed to create PID temp file"
                return 1
            }
            printf '%s %s\n' "$$" "$(date +%s)" > "$tmp_pid"
            mv "$tmp_pid" "$lockdir/pid" || {
                rm -rf "$lockdir"
                log_error "Failed to write PID to lock file"
                return 1
            }
            return 0
        fi

        # Lock exists — check if holder is still alive
        local holder_pid="" lock_time=""
        if [[ -f "$lockdir/pid" ]]; then
            read -r holder_pid lock_time < "$lockdir/pid" 2>/dev/null || true
        fi

        if [[ -n "$holder_pid" ]] && kill -0 "$holder_pid" 2>/dev/null; then
            # Guard against PID recycling: if lock is very old, treat as stale
            local now max_age
            now=$(date +%s)
            max_age=$(( ${AGENT_TIMEOUT:-600} * 2 + 300 ))
            if [[ -n "$lock_time" && $((now - lock_time)) -gt "$max_age" ]]; then
                log_warning "Lock held by PID $holder_pid but age exceeds ${max_age}s — treating as stale (PID likely recycled)"
            else
                log_error "Another aishore process is running (PID $holder_pid)"
                exit 1
            fi
        fi

        # Stale lock — remove and retry
        log_warning "Removing stale lock (PID ${holder_pid:-unknown} no longer running)"
        rm -rf "$lockdir"
    done

    log_error "Failed to acquire lock after 2 attempts"
    exit 1
}

append_log() {
    local file="$1" msg="$2"
    mkdir -p "$(dirname "$file")" 2>/dev/null || true
    printf '%s\n' "$msg" >> "$file"
}

verify_checksum() {
    local file="$1" expected="$2"
    [[ -z "$expected" ]] && { log_error "No expected checksum provided"; return 1; }
    [[ -z "$_HASH_CMD" ]] && { log_warning "No sha256sum or shasum found — skipping checksum verification"; return 0; }
    local actual
    actual=$($_HASH_CMD "$file" | cut -d' ' -f1)
    [[ "$actual" == "$expected" ]]
}

require_tool() {
    local tool="$1"
    if ! command -v "$tool" &>/dev/null; then
        log_error "'$tool' is required but not installed. Please install it and try again."
        exit 1
    fi
}

