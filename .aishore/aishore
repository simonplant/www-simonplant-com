find_claude_md() {
    local dir="$PROJECT_ROOT"
    # Check common locations
    for path in "$dir/CLAUDE.md" "$dir/claude.md" "$dir/docs/CLAUDE.md"; do
        [[ -f "$path" ]] && { printf '%s\n' "$path"; return 0; }
    done
    return 0
}

find_project_docs() {
    local dir="$PROJECT_ROOT"
    local docs=""
    for path in "$dir/ARCHITECTURE.md" "$dir/docs/ARCHITECTURE.md" \
                "$dir/PRODUCT.md" "$dir/docs/PRODUCT.md"; do
        [[ -f "$path" ]] && docs="$docs @$path"
    done
    printf '%s\n' "$docs"
}

# Find the first matching PRD/product requirements file.
# Returns the path on stdout, or empty string if none found.
_find_prd() {
    for candidate in \
        "$PROJECT_ROOT/PRODUCT.md" "$PROJECT_ROOT/product.md" \
        "$PROJECT_ROOT/PRD.md" "$PROJECT_ROOT/prd.md" \
        "$PROJECT_ROOT/docs/PRODUCT.md" "$PROJECT_ROOT/docs/product.md" \
        "$PROJECT_ROOT/docs/PRD.md" "$PROJECT_ROOT/docs/prd.md" \
        "$PROJECT_ROOT/README.md"; do
        [[ -f "$candidate" ]] && { printf '%s\n' "$candidate"; return 0; }
    done
    return 0
}

# Return path to a temp file with only the last N lines of sprints.jsonl
recent_sprints_file() {
    local max_lines="${1:-20}"
    local src="$ARCHIVE_DIR/sprints.jsonl"
    [[ ! -f "$src" ]] && return 0
    local line_count
    line_count=$(wc -l < "$src")
    if [[ "$line_count" -le "$max_lines" ]]; then
        printf '%s\n' "@$src"
        return 0
    fi
    local tmp
    tmp="$(ensure_tmpdir)/recent_sprints.jsonl"
    tail -n "$max_lines" "$src" > "$tmp"
    printf '%s\n' "@$tmp"
}

