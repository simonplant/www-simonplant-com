# Error handling convention:
#   - All functions signal failure with: log_error "message"; return 1
#   - Functions must NEVER call exit 1 — only return 1
#   - Only main() and pre-flight guards (acquire_lock, require_tool) may call exit
#   - Every return 1 must be preceded by a log_error call (directly or via a called function)
log_header()  { echo -e "\n${BLUE}════════════════════════════════════════${NC}\n${BLUE}  $1${NC}\n${BLUE}════════════════════════════════════════${NC}"; }
log_subheader() { echo -e "\n${CYAN}─── $1 ───${NC}"; }
log_success() { echo -e "${GREEN}✓ $1${NC}"; }
log_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }
