release_lock() {
    rm -rf "$STATUS_DIR/.aishore.lock" 2>/dev/null || true
}

acquire_lock() {
    local lockdir="$STATUS_DIR/.aishore.lock"
    mkdir -p "$STATUS_DIR" 2>/dev/null || true

    # Migrate from old flock-based flat file
    [[ -f "$lockdir" ]] && rm -f "$lockdir"

    local attempt
    for (( attempt = 0; attempt < 2; attempt++ )); do
        if mkdir "$lockdir" 2>/dev/null; then
            echo $$ > "$lockdir/pid"
            return 0
        fi

        # Lock exists — check if holder is still alive
        local holder_pid
        holder_pid=$(cat "$lockdir/pid" 2>/dev/null) || holder_pid=""
        if [[ -n "$holder_pid" ]] && kill -0 "$holder_pid" 2>/dev/null; then
            log_error "Another aishore process is running (PID $holder_pid)"
            exit 1
        fi

        # Stale lock — remove and retry
        log_warning "Removing stale lock (PID ${holder_pid:-unknown} no longer running)"
        rm -rf "$lockdir"
    done

    log_error "Failed to acquire lock after 2 attempts"
    exit 1
}

append_log() {
    local file="$1" msg="$2"
    mkdir -p "$(dirname "$file")" 2>/dev/null || true
    printf '%s\n' "$msg" >> "$file"
}

verify_checksum() {
    local file="$1" expected="$2"
    [[ -z "$expected" ]] && { log_error "No expected checksum provided"; return 1; }
    [[ -z "$_HASH_CMD" ]] && { log_warning "No sha256sum or shasum found — skipping checksum verification"; return 0; }
    local actual
    actual=$($_HASH_CMD "$file" | cut -d' ' -f1)
    [[ "$actual" == "$expected" ]]
}

require_tool() {
    local tool="$1"
    if ! command -v "$tool" &>/dev/null; then
        log_error "'$tool' is required but not installed. Please install it and try again."
        exit 1
    fi
}

