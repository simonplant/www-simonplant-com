# Module loader — lazy-load functions from .aishore/lib/*.sh
declare -A _LOADED_MODULES

_load_module() {
    local mod="$1"
    [[ -n "${_LOADED_MODULES[$mod]+x}" ]] && return 0
    local mod_file="$AISHORE_ROOT/lib/${mod}.sh"
    if [[ ! -f "$mod_file" ]]; then
        log_error "Module not found: $mod_file"
        return 1
    fi
    # shellcheck source=/dev/null
    source "$mod_file" || { log_error "Failed to load module $mod from $mod_file"; return 1; }
    _LOADED_MODULES[$mod]=1
}

build_context() {
    local agent_role="${AGENT_CONTEXT_ROLE:-developer}"
    local context=""
    for arg in "$@"; do
        [[ -n "$context" ]] && context="$context $arg" || context="$arg"
    done
    # Developer/architect need CLAUDE.md and ARCHITECTURE.md/PRODUCT.md
    if [[ "$agent_role" == "developer" || "$agent_role" == "architect" || "$agent_role" == "refiner" ]]; then
        local claude_md; claude_md=$(find_claude_md)
        [[ -n "$claude_md" ]] && context="$context @$claude_md"
        local project_docs; project_docs=$(find_project_docs)
        [[ -n "$project_docs" ]] && context="$context $project_docs"
    fi
    printf '%s\n' "$context"
}

