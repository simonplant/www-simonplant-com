# ============================================================================
# AGENT EXECUTION
# ============================================================================

# Core process management: launch claude agent and wait for result.json or timeout.
# Args: agent_label model allowed_tools output_format prompt
#   agent_label   - name for logging
#   model         - model to use
#   allowed_tools - comma-separated tool list
#   output_format - "text" or "stream-json" (use "text" for --print capture)
#   prompt        - full prompt string (including context @-files)
# Optional: set AGENT_OUTPUT_FILE before calling to capture --print output to a file.
# Optional: set GROOM_MONITOR=true to track backlog changes during the poll loop.

# Helper: portable file hash for change detection (not cryptographic)
_file_hash() {
    if [[ -n "$_HASH_CMD" ]]; then
        $_HASH_CMD "$1" | cut -d' ' -f1
    else
        cksum "$1" | cut -d' ' -f1
    fi
}

# Helper: detect and report backlog file changes during grooming
_check_groom_progress() {
    local label="$1"
    local changed=false

    local _gp_f
    for _gp_f in "${BACKLOG_FILES[@]}"; do
        if [[ -f "$BACKLOG_DIR/$_gp_f" ]]; then
            local cur_hash
            cur_hash=$(_file_hash "$BACKLOG_DIR/$_gp_f")
            local hash_var
            hash_var="_groom_hash_$(printf '%s' "$_gp_f" | tr -c 'a-zA-Z0-9' '_')"
            local prev_hash="${!hash_var:-}"
            if [[ "$cur_hash" != "$prev_hash" ]]; then
                printf -v "$hash_var" '%s' "$cur_hash"
                changed=true
                local ready total
                ready=$(count_ready_items "$BACKLOG_DIR/$_gp_f")
                total=$(count_items "$BACKLOG_DIR/$_gp_f")
                log_agent "$label" "$_gp_f updated — $total items ($ready ready)"
            fi
        fi
    done

    if [[ "$changed" != "true" && $((elapsed % 30)) -eq 0 ]]; then
        log_agent "$label" "Working... (${elapsed}s elapsed)"
    fi
}

run_agent_process() {
    local agent_label="$1"
    local model="$2"
    local allowed_tools="$3"
    local output_format="$4"
    local prompt="$5"
    local max_turns="${6:-}"

    log_agent "$agent_label" "Starting (model: $model, timeout: ${AGENT_TIMEOUT}s${max_turns:+, max_turns: $max_turns})"
    local start_time
    start_time=$(date +%s)

    # Always capture agent output to a per-run log file for diagnostics
    local agent_log
    agent_log="$LOGS_DIR/${agent_label}-$(date +%Y%m%dT%H%M%S).log"
    LAST_AGENT_LOG="$agent_log"

    local has_setsid=false
    if command -v setsid &>/dev/null; then
        has_setsid=true
    fi

    local claude_args=(
        --model "$model"
        --permission-mode acceptEdits
        --allowedTools "$allowed_tools"
    )

    # Max turns limit
    if [[ -n "$max_turns" ]] && [[ "$max_turns" -gt 0 ]] 2>/dev/null; then
        claude_args+=(--max-turns "$max_turns")
    fi

    local _out_target="${AGENT_OUTPUT_FILE:-$agent_log}"

    if [[ -n "${AGENT_OUTPUT_FILE:-}" ]]; then
        claude_args+=(--print)
    else
        claude_args+=(--output-format "$output_format")
    fi

    if [[ "$has_setsid" == true ]]; then
        setsid env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
            claude "${claude_args[@]}" \
            -p "$prompt" > "$_out_target" 2>&1 &
    else
        env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
            claude "${claude_args[@]}" \
            -p "$prompt" > "$_out_target" 2>&1 &
    fi

    local agent_pid=$!
    local elapsed=0
    local got_result=false

    # Streaming: track how many lines of agent output we've already printed
    local _stream_lines_seen=0
    local _stream_log_file="${AGENT_OUTPUT_FILE:-$agent_log}"
    local _stream_enabled="$STREAMING_ENABLED"
    local _stream_max="$STREAMING_MAX_LINES"

    # Progress monitoring: track backlog file changes during grooming
    local monitor_backlogs="${GROOM_MONITOR:-false}"
    if [[ "$monitor_backlogs" == "true" ]]; then
        local _init_f
        for _init_f in "${BACKLOG_FILES[@]}"; do
            if [[ -f "$BACKLOG_DIR/$_init_f" ]]; then
                local hash_var
                hash_var="_groom_hash_$(printf '%s' "$_init_f" | tr -c 'a-zA-Z0-9' '_')"
                printf -v "$hash_var" '%s' "$(_file_hash "$BACKLOG_DIR/$_init_f")"
            fi
        done
    fi

    while [[ $elapsed -lt $AGENT_TIMEOUT ]]; do
        if ! kill -0 "$agent_pid" 2>/dev/null; then
            # Process exited — stream any remaining lines before breaking
            if [[ "$_stream_enabled" == "true" && -f "$_stream_log_file" ]]; then
                local _final_lines
                _final_lines=$(tail -n +"$((_stream_lines_seen + 1))" "$_stream_log_file" 2>/dev/null | head -n "$_stream_max") || true
                if [[ -n "$_final_lines" ]]; then
                    printf '%s\n' "$_final_lines"
                    _stream_lines_seen=$(wc -l < "$_stream_log_file" 2>/dev/null || echo "$_stream_lines_seen")
                fi
            fi
            # Detect agent crash: process exited but no result.json written
            if [[ ! -f "$STATUS_DIR/result.json" ]]; then
                local _exit_code=0
                wait "$agent_pid" 2>/dev/null || _exit_code=$?
                local _log_size=0
                [[ -f "$agent_log" ]] && _log_size=$(wc -c < "$agent_log" 2>/dev/null || echo 0)
                log_error "Agent process exited (code $_exit_code) without writing result.json (log: ${_log_size} bytes)"
                local _crash_detail="Agent crashed or was killed (exit code $_exit_code)"
                [[ "$_log_size" -lt 100 ]] && _crash_detail="$_crash_detail — empty log suggests startup failure or resource limit"
                printf '{"status":"fail","reason":"CRASH: %s"}\n' "$_crash_detail" \
                    > "$STATUS_DIR/result.json"
            fi
            break
        fi
        if [[ -f "$STATUS_DIR/result.json" ]]; then
            got_result=true
            sleep 2
            break
        fi
        sleep 5
        elapsed=$((elapsed + 5))

        # Stream new agent output lines (rate-limited)
        if [[ "$_stream_enabled" == "true" && -f "$_stream_log_file" ]]; then
            local _new_lines
            _new_lines=$(tail -n +"$((_stream_lines_seen + 1))" "$_stream_log_file" 2>/dev/null | head -n "$_stream_max") || true
            if [[ -n "$_new_lines" ]]; then
                printf '%s\n' "$_new_lines"
                local _printed
                _printed=$(printf '%s\n' "$_new_lines" | wc -l)
                _stream_lines_seen=$((_stream_lines_seen + _printed))
            fi
        fi

        # Check for backlog changes and report progress
        if [[ "$monitor_backlogs" == "true" && $((elapsed % 10)) -eq 0 ]]; then
            _check_groom_progress "$agent_label"
        elif [[ "$_stream_enabled" != "true" && $((elapsed % 30)) -eq 0 ]]; then
            log_agent "$agent_label" "Waiting for agent... (${elapsed}s elapsed)"
        fi
    done

    # Kill the process if it's still running
    if kill -0 "$agent_pid" 2>/dev/null; then
        if [[ "$got_result" != "true" ]]; then
            local timeout_min=$((AGENT_TIMEOUT / 60))
            local _timeout_item_id=""
            _timeout_item_id=$(jq -r '.item.id // ""' "$BACKLOG_DIR/sprint.json" 2>/dev/null) || true
            if [[ -n "$_timeout_item_id" ]]; then
                log_error "Agent timeout after ${timeout_min} minutes for ${_timeout_item_id}"
            else
                log_error "Agent timeout after ${timeout_min} minutes for ${agent_label}"
            fi
            # Write TIMEOUT result so the sprint loop treats this as a countable failure
            printf '{"status":"fail","reason":"TIMEOUT: agent exceeded %d-minute limit"}\n' "$timeout_min" \
                > "$STATUS_DIR/result.json"
        fi
        if [[ "$has_setsid" == true ]]; then
            kill -TERM -- -"$agent_pid" 2>/dev/null || kill -TERM "$agent_pid" 2>/dev/null
            sleep 2
            kill -KILL -- -"$agent_pid" 2>/dev/null || true
        else
            kill -TERM "$agent_pid" 2>/dev/null || true
            sleep 2
            kill -KILL "$agent_pid" 2>/dev/null || true
        fi
    fi

    wait "$agent_pid" 2>/dev/null || true

    # Copy AGENT_OUTPUT_FILE to agent log if used (so LAST_AGENT_LOG is always valid)
    if [[ -n "${AGENT_OUTPUT_FILE:-}" && -f "$AGENT_OUTPUT_FILE" ]]; then
        cp "$AGENT_OUTPUT_FILE" "$agent_log" 2>/dev/null || true
    fi

    local duration
    duration=$(($(date +%s) - start_time))
    log_agent "$agent_label" "Completed in ${duration}s"

    append_log "$LOGS_DIR/agent-runs.log" \
        "$(portable_date_iso)|$agent_label|${AGENT_MODE:-unknown}|${duration}s|$model"
}

# Run an agent interactively in the foreground (for agents that use AskUserQuestion).
# Unlike run_agent_process, this does NOT background via setsid or poll for result.json.
# Uses --system-prompt (not -p) so claude runs interactively and AskUserQuestion works.
run_agent_interactive() {
    local agent_name="$1"
    local mode="$2"
    local model="${3:-$MODEL_PRIMARY}"
    local _rai_ctx_name="${4:-}"
    local extra_prompt="${5:-}"

    local prompt_file="$AGENTS_DIR/${agent_name}.md"
    [[ ! -f "$prompt_file" ]] && { log_error "Agent not found: $agent_name"; return 1; }

    rm -f "$STATUS_DIR/result.json"

    local context_files
    if [[ -n "$_rai_ctx_name" ]]; then
        local -n _rai_ctx_ref="$_rai_ctx_name"
        context_files=$(AGENT_CONTEXT_ROLE="$agent_name" build_context "${_rai_ctx_ref[@]}")
    else
        context_files=$(AGENT_CONTEXT_ROLE="$agent_name" build_context)
    fi

    # Resolve @file references into inline content (--system-prompt doesn't expand @file)
    local resolved_context=""
    local _token
    for _token in $context_files; do
        if [[ "$_token" == @* ]]; then
            local _file="${_token#@}"
            if [[ -f "$_file" ]]; then
                resolved_context+="
--- ${_file} ---
$(cat "$_file")
"
            fi
        fi
    done

    local agent_perms="$PERMS_REFINER"
    local max_turns="$MAX_TURNS_REFINER"

    local prompt
    prompt=$(build_agent_prompt "$agent_name" "$mode" "$extra_prompt")

    # Combine resolved context files + agent prompt into system prompt
    local system_prompt="${resolved_context}

${prompt}"

    local agent_log
    agent_log="$LOGS_DIR/${agent_name}-$(date +%Y%m%dT%H%M%S).log"
    LAST_AGENT_LOG="$agent_log"

    log_agent "$agent_name" "Starting interactive session (model: $model, max_turns: $max_turns)"

    local start_time
    start_time=$(date +%s)

    local claude_args=(
        --model "$model"
        --permission-mode acceptEdits
        --allowedTools "$agent_perms"
        --system-prompt "$system_prompt"
    )
    if [[ -n "$max_turns" ]] && [[ "$max_turns" -gt 0 ]] 2>/dev/null; then
        claude_args+=(--max-turns "$max_turns")
    fi

    # Run INTERACTIVELY in foreground — no -p, no setsid, no piping.
    # AskUserQuestion prompts appear in the user's terminal.
    # Cannot pipe through tee — claude detects non-tty stdout and switches to print mode.
    # Use script(1) to capture output while preserving the pty.
    if command -v script &>/dev/null; then
        script -q -e -c "env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT claude $(printf '%q ' "${claude_args[@]}")" "$agent_log"
    else
        # Fallback: no logging for interactive sessions
        env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
            claude "${claude_args[@]}"
    fi

    local duration
    duration=$(($(date +%s) - start_time))
    log_agent "$agent_name" "Completed in ${duration}s"

    append_log "$LOGS_DIR/agent-runs.log" \
        "$(portable_date_iso)|$agent_name|${mode}|${duration}s|$model"
}

# Load a template file with {{VAR}} substitution.
# Usage: _load_template <filename> [VAR1 VALUE1 VAR2 VALUE2 ...]
_load_template() {
    local name="$1"; shift
    local tmpl_path="$AISHORE_ROOT/templates/$name"
    [[ -f "$tmpl_path" ]] || { log_error "Template not found: $name"; return 1; }
    local content
    content=$(<"$tmpl_path")
    local var val
    while [[ $# -ge 2 ]]; do
        var="$1"; val="$2"; shift 2
        content="${content//\{\{$var\}\}/$val}"
    done
    printf '%s' "$content"
}

build_agent_prompt() {
    local agent_name="$1"
    local mode="$2"
    local extra_prompt="${3:-}"

    local prompt_file="$AGENTS_DIR/${agent_name}.md"
    [[ ! -f "$prompt_file" ]] && { log_error "Agent not found: $agent_name"; return 1; }

    # Read prompt file; strip mode-specific sections when not in that mode
    local prompt_content
    if [[ "$agent_name" == "groomer" && "$mode" != "populate" ]]; then
        prompt_content="$(sed '/^## Populate Mode/,$d' "$prompt_file" | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')"
    elif [[ "$agent_name" == "architect" && "$mode" == "groom" ]]; then
        # Strip Review Mode section, keep Groom Mode section
        prompt_content="$(sed '/^## Review Mode/,/^## Groom Mode/{/^## Groom Mode/!d}' "$prompt_file")"
        # Inject explicit mode indicator so the architect knows its mode without inferring from stripped sections
        prompt_content="You are in groom mode.
${prompt_content}"
    elif [[ "$agent_name" == "architect" ]]; then
        # Strip Groom Mode section (review mode)
        prompt_content="$(sed '/^## Groom Mode/,$d' "$prompt_file" | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')"
        # Inject explicit mode indicator so the architect knows its mode without inferring from stripped sections
        prompt_content="You are in review mode.
${prompt_content}"
    elif [[ "$agent_name" == "refiner" && "$mode" == "feedback" ]]; then
        # Strip Refine Mode section, keep Feedback Mode section
        prompt_content="$(sed '/^## Refine Mode/,/^## Feedback Mode/{/^## Feedback Mode/!d}' "$prompt_file")"
        prompt_content="You are in feedback mode.
${prompt_content}"
    elif [[ "$agent_name" == "refiner" ]]; then
        # Strip Feedback Mode section (refine mode)
        prompt_content="$(sed '/^## Feedback Mode/,$d' "$prompt_file" | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')"
        prompt_content="You are in refine mode.
${prompt_content}"
    else
        prompt_content="$(cat "$prompt_file")"
    fi

    # Build orchestrator injections from templates
    local validate_hint=""
    if [[ "$agent_name" == "developer" ]]; then
        validate_hint=$'\n'"$(_load_template prompt-developer-hints.md)"

        # Inject scope constraints if the item declares scope globs
        local item_scope_json
        item_scope_json=$(jq -r '.item.scope // empty' "$BACKLOG_DIR/sprint.json" 2>/dev/null)
        if [[ -n "$item_scope_json" ]] && [[ "$(jq 'length' <<< "$item_scope_json")" -gt 0 ]]; then
            local scope_list
            scope_list=$(jq -r '.[]' <<< "$item_scope_json" | sed 's/^/- `/' | sed 's/$/`/')
            validate_hint="$validate_hint

## File Scope Advisory
The following file globs define the preferred scope for this item:
${scope_list}
Scope is advisory, not strict — stay within these paths when possible. Out-of-scope changes are not failures but will be flagged as warnings in review."
        fi

        if [[ -n "$FIX_CMD" ]]; then
            validate_hint="$validate_hint

## Auto-Fix
After you finish, the orchestrator will automatically run \`$FIX_CMD\` to fix lint/formatting issues. Do not worry about auto-fixable style issues — focus on correctness and AC."
        fi
    elif [[ "$agent_name" == "validator" ]]; then
        validate_hint=$'\n'"$(_load_template prompt-validator-hints.md)"
    elif [[ "$agent_name" == "groomer" || ("$agent_name" == "architect" && "$mode" == "groom") ]]; then
        local cli_role_lines
        if [[ "$agent_name" == "groomer" ]]; then
            cli_role_lines='.aishore/aishore backlog add --type feat --title "..." --desc "..." --priority should
.aishore/aishore backlog add --type bug --title "..." --desc "..." --priority should
.aishore/aishore backlog edit <ID> --ready --priority must --groomed-at --groomed-notes "..."'
        else
            cli_role_lines='.aishore/aishore backlog add --type feat --title "..." --intent "..." --desc "..." --priority must --ready --steps "..." --steps "..." --ac "..." --ac "..."
.aishore/aishore backlog edit <ID> --ready --groomed-at --groomed-notes "..."
.aishore/aishore backlog edit <ID> --depends-on FEAT-XXX,FEAT-YYY'
        fi
        validate_hint=$'\n'"$(_load_template prompt-groom-hints.md \
            "CLI_ROLE_LINES" "$cli_role_lines" \
            "GROOM_MAX_ITEMS" "$GROOM_MAX_ITEMS" \
            "GROOM_MIN_PRIORITY" "$GROOM_MIN_PRIORITY")"
    elif [[ "$agent_name" == "refiner" ]]; then
        local prd_path
        prd_path=$(_find_prd)
        validate_hint="
## Target Document
Edit \`$prd_path\` directly. Preserve section structure. Be specific and concrete — write for the groomer agent that will decompose this into backlog items.

## Interview Tool
Use \`AskUserQuestion\` to interview the user. Ask 1-2 questions at a time. The user can answer or say \"done\" to end the interview."
    fi

    local prompt
    prompt="$prompt_content
${extra_prompt:+
$extra_prompt}${validate_hint:+
$validate_hint}

## Mode
$mode
$(build_completion_contract)"
    printf '%s\n' "$prompt"
}

run_agent() {
    local agent_name="$1"
    local mode="$2"
    local model="${3:-$MODEL_PRIMARY}"
    local _ra_ctx_name="${4:-}"
    local output_file="${5:-}"
    local extra_prompt="${6:-}"

    local prompt_file="$AGENTS_DIR/${agent_name}.md"
    [[ ! -f "$prompt_file" ]] && { log_error "Agent not found: $agent_name"; return 1; }

    rm -f "$STATUS_DIR/result.json"

    # Developer command override: run a shell command instead of Claude
    # The command runs in the worktree with sprint.json available, and must write result.json
    if [[ "$agent_name" == "developer" && -n "$DEVELOPER_CMD" ]]; then
        log_agent "developer" "Running developer command: $DEVELOPER_CMD"
        local agent_log
        agent_log="$LOGS_DIR/developer-$(date +%Y%m%dT%H%M%S).log"
        LAST_AGENT_LOG="$agent_log"
        if bash -c "$DEVELOPER_CMD" > "$agent_log" 2>&1; then
            log_agent "developer" "Command completed"
        else
            local _dc_exit=$?
            log_error "Developer command failed (exit $_dc_exit)"
            if [[ ! -f "$STATUS_DIR/result.json" ]]; then
                printf '{"status":"fail","reason":"Developer command exited %d"}\n' "$_dc_exit" \
                    > "$STATUS_DIR/result.json"
            fi
        fi
        return 0
    fi

    local context_files
    if [[ -n "$_ra_ctx_name" ]]; then
        local -n _ra_ctx_ref="$_ra_ctx_name"
        context_files=$(AGENT_CONTEXT_ROLE="$agent_name" build_context "${_ra_ctx_ref[@]}")
    else
        context_files=$(AGENT_CONTEXT_ROLE="$agent_name" build_context "@$BACKLOG_DIR/sprint.json")
    fi

    # Derive permissions based on agent role and mode
    local agent_perms
    case "$agent_name" in
        developer)  agent_perms="$PERMS_DEVELOPER" ;;
        validator)  agent_perms="$PERMS_VALIDATOR" ;;
        architect)
            if [[ "$mode" == "groom" ]]; then
                agent_perms="$PERMS_DEVELOPER"
            else
                agent_perms="$PERMS_REVIEWER"
            fi ;;
        groomer)    agent_perms="$PERMS_DEVELOPER" ;;
        refiner)    agent_perms="$PERMS_REFINER" ;;
        *)          agent_perms="$PERMS_DEVELOPER" ;;
    esac

    # Resolve max_turns based on agent role
    local max_turns
    case "$agent_name" in
        developer)
            max_turns="$MAX_TURNS_DEVELOPER" ;;
        validator)
            max_turns="$MAX_TURNS_VALIDATOR" ;;
        groomer|architect)
            max_turns="$MAX_TURNS_GROOMER" ;;
        refiner)
            max_turns="$MAX_TURNS_REFINER" ;;
        *)
            max_turns="$MAX_TURNS_DEVELOPER" ;;
    esac

    local prompt
    prompt=$(build_agent_prompt "$agent_name" "$mode" "$extra_prompt")

    if [[ -n "$output_file" ]]; then
        AGENT_OUTPUT_FILE="$output_file" AGENT_MODE="$mode" run_agent_process "$agent_name" "$model" \
            "$agent_perms" "" \
            "$context_files
$prompt" "$max_turns"
    else
        AGENT_MODE="$mode" run_agent_process "$agent_name" "$model" \
            "$agent_perms" "text" \
            "$context_files
$prompt" "$max_turns"
    fi
}

show_failure_log_tail() {
    if [[ -n "$LAST_AGENT_LOG" && -f "$LAST_AGENT_LOG" ]]; then
        local line_count
        line_count=$(wc -l < "$LAST_AGENT_LOG" 2>/dev/null || echo 0)
        if [[ "$line_count" -gt 0 ]]; then
            echo ""
            echo -e "${RED}── Last 20 lines of agent log ──${NC}"
            tail -n 20 "$LAST_AGENT_LOG" 2>/dev/null || true
            echo -e "${RED}── End of log tail ──${NC}"
        fi
        log_info "Full agent log: $LAST_AGENT_LOG"
    fi
}

check_result() {
    local role="${1:-}"

    if [[ ! -f "$STATUS_DIR/result.json" ]]; then
        log_error "No result file - agent may have crashed"
        show_failure_log_tail
        return 1
    fi

    local status
    # Support both simple format {"status":"pass"} and detailed format {"overall":"PASS"}
    status=$(jq -r '.status // .overall // "unknown"' "$STATUS_DIR/result.json" 2>/dev/null)
    # Normalize to lowercase so PASS/pass both match
    status=$(printf '%s\n' "$status" | tr '[:upper:]' '[:lower:]')

    if [[ "$status" == "pass" ]]; then
        # Enforce maturity protocol: developer must include .phases evidence
        if [[ "$role" == "developer" ]]; then
            local has_phases
            has_phases=$(jq -r '.phases // empty' "$STATUS_DIR/result.json" 2>/dev/null || true)
            if [[ -z "$has_phases" || "$has_phases" == "null" ]]; then
                log_error "Developer result missing maturity phases evidence — rejecting as incomplete"
                return 1
            fi

            # Cross-check: developer's reported verify_commands_run must match actual count
            local sprint_file="$BACKLOG_DIR/sprint.json"
            if [[ -f "$sprint_file" ]]; then
                local actual_verify_count reported_verify_count
                actual_verify_count=$(jq '[(.item.acceptanceCriteria // [])[] | select(type == "object" and .verify != null)] | length' "$sprint_file" 2>/dev/null || echo 0)
                reported_verify_count=$(jq -r '.phases.harden.verify_commands_run // 0' "$STATUS_DIR/result.json" 2>/dev/null || echo 0)
                if [[ "$actual_verify_count" -gt 0 && "$reported_verify_count" -ne "$actual_verify_count" ]]; then
                    log_error "Developer reported running $reported_verify_count verify commands but sprint has $actual_verify_count — rejecting (run ALL AC verify commands in Phase 3)"
                    return 1
                fi
            fi
        fi

        local summary
        summary=$(jq -r '.summary // .checks // "completed"' "$STATUS_DIR/result.json")
        log_success "$summary"
        return 0
    else
        local reason
        reason=$(jq -r '.reason // "unknown error"' "$STATUS_DIR/result.json")
        if [[ "$reason" == "unknown error" ]]; then
            # Include actual file contents to aid debugging
            local raw_content
            raw_content=$(cat "$STATUS_DIR/result.json" 2>/dev/null || echo "(unreadable)")
            log_error "Unexpected result format: $raw_content"
        else
            log_error "$reason"
        fi
        show_failure_log_tail
        return 1
    fi
}

# Scope enforcement — warn on out-of-scope file modifications (advisory only).
# Reads .item.scope from sprint.json, compares changed files against scope globs,
# and calls log_warning for each file outside scope. Never fails the sprint.
_check_scope_warnings() {
    local _scope_globs
    _scope_globs=$(jq -r '.item.scope // [] | .[]' "$BACKLOG_DIR/sprint.json" 2>/dev/null || true)
    [[ -z "$_scope_globs" || -z "${AISHORE_BASE_BRANCH:-}" ]] && return 0
    # Build combined regex from all scope globs
    local _combined_re="" _sg _re
    while IFS= read -r _sg; do
        _re=$(printf '%s' "$_sg" | sed -e 's/\./\\./g' -e 's/\*\*/\x00/g' -e 's/\*/[^\/]*/g' -e 's/\x00/.*/g' -e 's/?/./g')
        [[ -n "$_combined_re" ]] && _combined_re="${_combined_re}|"
        _combined_re="${_combined_re}^${_re}\$"
    done <<< "$_scope_globs"
    # Compare changed files against scope globs and warn on mismatches
    local _scope_diff _cf
    _scope_diff=$(git diff --name-only "$AISHORE_BASE_BRANCH" 2>/dev/null || true)
    while IFS= read -r _cf; do [[ -z "$_cf" ]] && continue
        [[ "$_cf" =~ ${_combined_re} ]] || log_warning "Out-of-scope file modified: $_cf"
    done <<< "$_scope_diff"
    return 0
}

run_ac_verification() {
    local sprint_file="$BACKLOG_DIR/sprint.json"
    [[ ! -f "$sprint_file" ]] && return 0

    local ac_json
    if ! ac_json=$(jq -r '.item.acceptanceCriteria // []' "$sprint_file" 2>&1); then
        log_error "Failed to parse acceptanceCriteria from sprint.json: $ac_json"
        return 1
    fi
    [[ -z "$ac_json" || "$ac_json" == "null" || "$ac_json" == "[]" ]] && return 0

    # Filter to objects with .verify field and get count in one pass
    local verifiable verify_count
    if ! verifiable=$(printf '%s\n' "$ac_json" | jq '[.[] | select(type == "object" and .verify != null)]' 2>&1); then
        log_error "Failed to parse AC verify fields: $verifiable"
        return 1
    fi
    verify_count=$(jq 'length' <<< "$verifiable" 2>/dev/null || echo 0)
    [[ "$verify_count" -eq 0 ]] && return 0

    log_info "Running $verify_count AC verification command(s)" >&2
    local all_passed=true
    local report=""
    local idx=0

    while IFS=$'\t' read -r ac_text ac_cmd; do
        idx=$((idx + 1))

        local ac_ok=true
        local ac_tmpfile
        ac_tmpfile="$(ensure_tmpdir)/ac_verify_${idx}.txt"
        run_timed_command "$ac_cmd" "$ac_tmpfile" || ac_ok=false
        local ac_output
        ac_output=$(truncate_output "$ac_tmpfile")
        rm -f "$ac_tmpfile"

        if [[ "$ac_ok" == "true" ]]; then
            report="${report}  PASS: ${ac_text}"$'\n'
            log_success "AC: $ac_text" >&2
        else
            report="${report}  FAIL: ${ac_text} (cmd: ${ac_cmd})"$'\n'"    Output: ${ac_output}"$'\n'
            log_error "AC: $ac_text"
            all_passed=false
        fi
    done < <(jq -r '.[] | [(.text // "unnamed"), .verify] | @tsv' <<< "$verifiable")

    [[ -n "$report" ]] && printf '%s\n' "$report"
    [[ "$all_passed" == "true" ]] && return 0 || return 1
}

# ============================================================================
# REGRESSION SUITE — verify commands compound across sprints
# ============================================================================

# Save verify commands from a completed sprint into the persistent regression file.
# Called after mark_complete — only passing items contribute to the regression suite.
_save_regression_entries() {
    local sprint_file="$1"
    local regression_file="$ARCHIVE_DIR/regression.jsonl"
    [[ ! -f "$sprint_file" ]] && return 0

    local item_id
    item_id=$(jq -r '.item.id // ""' "$sprint_file" 2>/dev/null)
    [[ -z "$item_id" ]] && return 0

    # Extract AC entries that have verify commands
    local entries
    entries=$(jq -c --arg id "$item_id" --arg date "$(date +%Y-%m-%d)" '
        [.item.acceptanceCriteria // [] | .[] | select(type == "object" and .verify != null)] |
        .[] | {itemId: $id, date: $date, text: .text, verify: .verify}
    ' "$sprint_file" 2>/dev/null) || return 0

    [[ -z "$entries" ]] && return 0

    mkdir -p "$ARCHIVE_DIR"
    printf '%s\n' "$entries" >> "$regression_file"
    local count
    count=$(printf '%s\n' "$entries" | wc -l)
    log_info "Regression suite: $count check(s) saved from $item_id"
}

# Run the accumulated regression suite — all verify commands from prior completed sprints.
# Returns 0 if all pass (or no suite exists), 1 if any fail.
_run_regression_suite() {
    local regression_file="$ARCHIVE_DIR/regression.jsonl"
    [[ ! -f "$regression_file" ]] && return 0
    [[ ! -s "$regression_file" ]] && return 0

    local total
    total=$(wc -l < "$regression_file")
    [[ "$total" -eq 0 ]] && return 0

    # Load regression-skip.json if present (array of item IDs to skip)
    local -A skip_items=()
    local skip_file="$ARCHIVE_DIR/regression-skip.json"
    if [[ -f "$skip_file" ]]; then
        local skip_id
        while IFS= read -r skip_id; do
            [[ -n "$skip_id" && "$skip_id" != "null" ]] && skip_items["$skip_id"]=1
        done < <(jq -r '.[]' "$skip_file" 2>/dev/null || true)
    fi
    local skipped=0

    log_info "Regression suite: running $total check(s) from prior sprints"

    local failed=0 passed_count=0 line_num=0
    while IFS= read -r entry; do
        line_num=$((line_num + 1))
        local cmd text reg_item_id
        cmd=$(printf '%s' "$entry" | jq -r '.verify' 2>/dev/null) || continue
        text=$(printf '%s' "$entry" | jq -r '.text // "unnamed"' 2>/dev/null)
        reg_item_id=$(printf '%s' "$entry" | jq -r '.itemId // "?"' 2>/dev/null)

        [[ -z "$cmd" || "$cmd" == "null" ]] && continue

        # Skip entries from items in regression-skip.json
        if [[ -n "${skip_items[$reg_item_id]+_}" ]]; then
            skipped=$((skipped + 1))
            continue
        fi

        local reg_tmpfile
        reg_tmpfile="$(ensure_tmpdir)/regression_${line_num}.txt"
        if run_timed_command "$cmd" "$reg_tmpfile"; then
            rm -f "$reg_tmpfile"
            passed_count=$((passed_count + 1))
        else
            failed=$((failed + 1))
            local reg_output
            reg_output=$(truncate_output "$reg_tmpfile")
            rm -f "$reg_tmpfile"
            log_error "Regression FAIL [$reg_item_id]: $text"
            log_error "  Command: $cmd"
            [[ -n "$reg_output" ]] && log_error "  Output (truncated): $reg_output"
        fi
    done < "$regression_file"

    [[ "$skipped" -gt 0 ]] && log_info "Regression suite: skipped $skipped check(s) via regression-skip.json"
    if [[ "$failed" -gt 0 ]]; then
        log_error "Regression suite: $failed/$total check(s) failed — prior work may be broken"
        return 1
    fi
    log_success "Regression suite: $((passed_count)) check(s) passed"
    return 0
}

