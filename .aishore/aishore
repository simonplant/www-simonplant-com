}

reverse_lines() {
    if command -v tac &>/dev/null; then
        tac
    else
        awk '{lines[NR]=$0} END{for(i=NR;i>=1;i--) print lines[i]}'
    fi
}

# Convert a comma-separated or newline-separated string to a JSON array
