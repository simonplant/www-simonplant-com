# Client (bundled into the browser JS) — PostHog project API key.
PUBLIC_POSTHOG_KEY=phc_your_key_here

# Server only — target for the /ingest Cloudflare Pages Function proxy.
# Optional: defaults to https://us.i.posthog.com when unset. Not PUBLIC_*,
# so it never ships to the browser. Set via a Cloudflare Pages env binding.
POSTHOG_HOST=https://us.i.posthog.com
