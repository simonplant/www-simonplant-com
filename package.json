{
  "name": "www-simonplant-com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check:perf": "npm run build && stat -c%s dist/index.html | awk '{exit ($1 >= 102400)}'",
    "posthog:dashboard": "node --env-file-if-exists=.env.local scripts/posthog-dashboard.mjs",
    "annotate": "node --env-file-if-exists=.env.local scripts/annotate.mjs",
    "utm": "node scripts/utm.mjs"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "protobufjs": "^7.5.6",
    "@protobufjs/utf8": ">=1.1.1",
    "dompurify": "^3.4.0",
    "devalue": ">=5.8.1",
    "fast-uri": ">=3.1.2",
    "fast-xml-builder": ">=1.1.7",
    "fast-xml-parser": ">=5.7.0",
    "vite": "^7.3.3"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "posthog-js": "^1.388.1",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "pagefind": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
