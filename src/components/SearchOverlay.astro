---
---

<div id="search-overlay" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="Site search">
  <div id="search-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
  <div class="relative mx-auto mt-[12vh] w-full max-w-xl px-4">
    <div class="rounded-lg border border-border-default bg-surface-elevated shadow-2xl overflow-hidden">
      <div id="search-container" class="p-4">
        <div class="flex items-center gap-3 text-text-muted text-sm">
          <svg class="w-5 h-5 shrink-0 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Loading search...
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* Pagefind UI overrides for dark theme with amber accents */
  .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #d4a853;
    --pagefind-ui-text: #e8e6e1;
    --pagefind-ui-background: #16161e;
    --pagefind-ui-border: rgba(255, 255, 255, 0.1);
    --pagefind-ui-tag: #111118;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-image-border-radius: 6px;
    --pagefind-ui-image-box-ratio: 0;
    --pagefind-ui-font: Inter, system-ui, sans-serif;
  }

  .pagefind-ui .pagefind-ui__search-input {
    background: #111118 !important;
    color: #e8e6e1 !important;
    font-weight: 400 !important;
  }

  .pagefind-ui .pagefind-ui__search-input::placeholder {
    color: #6b6b7b !important;
  }

  .pagefind-ui .pagefind-ui__search-input:focus {
    outline: none !important;
    border-color: #d4a853 !important;
    box-shadow: 0 0 0 1px #d4a853 !important;
  }

  .pagefind-ui .pagefind-ui__search-clear {
    color: #a0a0b0 !important;
    background: none !important;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #d4a853 !important;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    color: #e6c36a !important;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    color: #a0a0b0 !important;
  }

  .pagefind-ui mark {
    background: rgba(212, 168, 83, 0.25) !important;
    color: #e6c36a !important;
  }

  .pagefind-ui .pagefind-ui__message {
    color: #6b6b7b !important;
  }

  .pagefind-ui .pagefind-ui__button {
    background: #111118 !important;
    color: #d4a853 !important;
    border-color: rgba(255, 255, 255, 0.1) !important;
  }

  .pagefind-ui .pagefind-ui__button:hover {
    border-color: #d4a853 !important;
  }
</style>

<script is:inline>
  (function () {
    var pagefindLoaded = false;
    var overlay = document.getElementById('search-overlay');
    var backdrop = document.getElementById('search-backdrop');
    var container = document.getElementById('search-container');

    function openSearch() {
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      if (!pagefindLoaded) {
        pagefindLoaded = true;
        loadPagefind();
      } else {
        focusInput();
      }
    }

    function closeSearch() {
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
    }

    function focusInput() {
      var input = container.querySelector('.pagefind-ui__search-input');
      if (input) {
        input.focus();
        input.select();
      }
    }

    async function loadPagefind() {
      try {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);

        var mod = await import('/pagefind/pagefind-ui.js');

        container.innerHTML = '';
        new mod.PagefindUI({
          element: container,
          showSubResults: true,
          showImages: false,
          autofocus: true,
        });

        // Track search queries (debounced)
        var searchTimer = null;
        var lastQuery = '';
        container.addEventListener('input', function (e) {
          if (!e.target.classList.contains('pagefind-ui__search-input')) return;
          clearTimeout(searchTimer);
          searchTimer = setTimeout(function () {
            var query = e.target.value.trim();
            if (query && query !== lastQuery && query.length >= 2) {
              lastQuery = query;
              if (window.__posthog) {
                var resultCount = container.querySelectorAll('.pagefind-ui__result').length;
                window.__posthog.capture('search_query', {
                  query: query,
                  result_count: resultCount
                });
              }
            }
          }, 1000);
        });
      } catch (e) {
        container.innerHTML = '<p style="color:#6b6b7b;font-size:0.875rem;padding:0.5rem;">Search index not available. Run a production build to generate it.</p>';
      }
    }

    // Cmd/Ctrl+K to open
    document.addEventListener('keydown', function (e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (overlay.classList.contains('hidden')) {
          openSearch();
        } else {
          closeSearch();
        }
      }

      if (e.key === 'Escape' && !overlay.classList.contains('hidden')) {
        closeSearch();
      }
    });

    // Click backdrop to close
    backdrop.addEventListener('click', closeSearch);

    // Expose open function for Nav trigger
    window.__openSearch = openSearch;
  })();
</script>
