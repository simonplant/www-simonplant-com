---
// CopyCode — adds a one-click copy button to every <pre> element on the page.
// Pure vanilla JS, no framework dependencies.
---

<script>
  document.querySelectorAll('pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'copy-code-btn';
    btn.textContent = 'Copy';
    btn.type = 'button';
    btn.addEventListener('click', async () => {
      try {
        const code = pre.querySelector('code');
        const text = (code || pre).textContent || '';
        await navigator.clipboard.writeText(text);
        btn.textContent = 'Copied!';
        btn.setAttribute('data-copied', '');
        // Same bare-id slug format as ScrollDepth/autocapture, so per-article
        // insights can join across events.
        const slug =
          document.querySelector('[data-ph-capture-attribute-slug]')?.getAttribute('data-ph-capture-attribute-slug') ||
          window.location.pathname;
        window.phCapture?.('code_block_copied', { slug });
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.removeAttribute('data-copied');
        }, 2000);
      } catch {
        btn.textContent = 'Error';
        setTimeout(() => {
          btn.textContent = 'Copy';
        }, 2000);
      }
    });
    pre.appendChild(btn);
  });
</script>
