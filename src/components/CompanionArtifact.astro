---
interface Props {
  title: string;
  type: 'checklist' | 'template' | 'framework' | 'matrix';
  description: string;
  githubUrl: string;
}

const { title, type, description, githubUrl } = Astro.props;

const typeLabels: Record<string, string> = {
  checklist: 'Checklist',
  template: 'Template',
  framework: 'Framework',
  matrix: 'Matrix',
};
---

<a
  href={githubUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="block bg-surface-card border border-border-subtle rounded-lg p-5 hover:border-primary-400/40 transition-colors group"
>
  <div class="flex items-start gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-2">
        <h3 class="font-serif text-lg text-gray-50 group-hover:text-primary-400 transition-colors">{title}</h3>
        <span class="text-xs font-sans font-medium uppercase tracking-wider text-primary-400 bg-primary-400/10 px-2 py-0.5 rounded-full whitespace-nowrap">
          {typeLabels[type]}
        </span>
      </div>
      <p class="text-text-secondary text-sm font-prose leading-relaxed">{description}</p>
    </div>
    <span class="text-text-muted group-hover:text-primary-400 transition-colors shrink-0 mt-1" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    </span>
  </div>
</a>
