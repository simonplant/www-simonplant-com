---
/**
 * EcosystemMap — inline SVG relationship diagram showing how the four
 * products (ClawHQ, AIShore, Easy Markdown, Clawdius) connect in the
 * agent infrastructure lifecycle.
 *
 * Desktop: spatial 2×2 layout with directional arrows.
 * Mobile:  vertical stacked flow (same SVG, different viewBox via CSS).
 */
---

<div class="ecosystem-map" role="img" aria-label="Product ecosystem relationship map showing how AIShore plans work for ClawHQ, ClawHQ manages Clawdius, and Clawdius produces content processed by Easy Markdown">
  <!-- Desktop / wide layout -->
  <svg
    class="ecosystem-svg ecosystem-svg--wide"
    viewBox="0 0 800 420"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    fill="none"
  >
    <defs>
      <marker id="arrow-right" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
        <path d="M1 1 L7 4 L1 7" stroke="#d4a853" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      </marker>
      <marker id="arrow-down" markerWidth="8" markerHeight="8" refX="4" refY="7" orient="auto">
        <path d="M1 1 L7 4 L1 7" stroke="#d4a853" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      </marker>
      <marker id="arrow-left" markerWidth="8" markerHeight="8" refX="1" refY="4" orient="auto">
        <path d="M1 1 L7 4 L1 7" stroke="#d4a853" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      </marker>
    </defs>

    <!-- ── Nodes ── -->
    <!-- AIShore (top-left) -->
    <rect x="40" y="40" width="260" height="110" rx="8" fill="#111118" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
    <text x="170" y="82" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="20" fill="#f9fafb">AIShore</text>
    <text x="170" y="106" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#a0a0b0">Sprint Orchestration</text>
    <text x="170" y="126" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#6b6b7b">Backlog → structured work items</text>

    <!-- ClawHQ (top-right) -->
    <rect x="500" y="40" width="260" height="110" rx="8" fill="#111118" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
    <circle cx="524" cy="54" r="4" fill="#d4a853" opacity="0.7" />
    <text x="630" y="82" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="20" fill="#f9fafb">ClawHQ</text>
    <text x="630" y="106" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#a0a0b0">Agent Orchestration</text>
    <text x="630" y="126" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#6b6b7b">Dispatch, monitor &amp; enforce policy</text>

    <!-- Clawdius (bottom-right) -->
    <rect x="500" y="270" width="260" height="110" rx="8" fill="#111118" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
    <text x="630" y="312" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="20" fill="#f9fafb">Clawdius</text>
    <text x="630" y="336" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#a0a0b0">Content Production Agent</text>
    <text x="630" y="356" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#6b6b7b">Series, commentary &amp; KB entries</text>

    <!-- Easy Markdown (bottom-left) -->
    <rect x="40" y="270" width="260" height="110" rx="8" fill="#111118" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
    <text x="170" y="312" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="20" fill="#f9fafb">Easy Markdown</text>
    <text x="170" y="336" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#a0a0b0">Content Processing</text>
    <text x="170" y="356" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#6b6b7b">Schema validation &amp; rendering</text>

    <!-- ── Connections ── -->
    <!-- AIShore → ClawHQ (horizontal right) -->
    <line x1="300" y1="95" x2="498" y2="95" stroke="#d4a853" stroke-width="1.5" stroke-dasharray="6 4" marker-end="url(#arrow-right)" opacity="0.6" />
    <text x="400" y="84" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#d4a853" opacity="0.8">plans work</text>

    <!-- ClawHQ → Clawdius (vertical down) -->
    <line x1="630" y1="150" x2="630" y2="268" stroke="#d4a853" stroke-width="1.5" stroke-dasharray="6 4" marker-end="url(#arrow-down)" opacity="0.6" />
    <text x="656" y="215" text-anchor="start" font-family="Inter, sans-serif" font-size="11" fill="#d4a853" opacity="0.8">manages</text>

    <!-- Clawdius → Easy Markdown (horizontal left) -->
    <line x1="498" y1="325" x2="302" y2="325" stroke="#d4a853" stroke-width="1.5" stroke-dasharray="6 4" marker-end="url(#arrow-left)" opacity="0.6" />
    <text x="400" y="314" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#d4a853" opacity="0.8">produces content</text>

    <!-- Flow direction indicator -->
    <text x="400" y="210" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="14" fill="#6b6b7b" opacity="0.5">Agent Infrastructure Lifecycle</text>
  </svg>

  <!-- Mobile / narrow layout -->
  <svg
    class="ecosystem-svg ecosystem-svg--narrow"
    viewBox="0 0 340 680"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    fill="none"
  >
    <defs>
      <marker id="arrow-mobile" markerWidth="8" markerHeight="8" refX="4" refY="7" orient="auto">
        <path d="M1 1 L7 4 L1 7" stroke="#d4a853" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      </marker>
    </defs>

    <!-- AIShore -->
    <rect x="20" y="10" width="300" height="100" rx="8" fill="#111118" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
    <text x="170" y="48" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="19" fill="#f9fafb">AIShore</text>
    <text x="170" y="70" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#a0a0b0">Sprint Orchestration</text>
    <text x="170" y="90" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#6b6b7b">Backlog → structured work items</text>

    <!-- Arrow down -->
    <line x1="170" y1="110" x2="170" y2="164" stroke="#d4a853" stroke-width="1.5" stroke-dasharray="6 4" marker-end="url(#arrow-mobile)" opacity="0.6" />
    <text x="190" y="142" font-family="Inter, sans-serif" font-size="11" fill="#d4a853" opacity="0.8">plans work</text>

    <!-- ClawHQ -->
    <rect x="20" y="170" width="300" height="100" rx="8" fill="#111118" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
    <circle cx="44" cy="184" r="4" fill="#d4a853" opacity="0.7" />
    <text x="170" y="208" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="19" fill="#f9fafb">ClawHQ</text>
    <text x="170" y="230" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#a0a0b0">Agent Orchestration</text>
    <text x="170" y="250" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#6b6b7b">Dispatch, monitor &amp; enforce policy</text>

    <!-- Arrow down -->
    <line x1="170" y1="270" x2="170" y2="324" stroke="#d4a853" stroke-width="1.5" stroke-dasharray="6 4" marker-end="url(#arrow-mobile)" opacity="0.6" />
    <text x="190" y="302" font-family="Inter, sans-serif" font-size="11" fill="#d4a853" opacity="0.8">manages</text>

    <!-- Clawdius -->
    <rect x="20" y="330" width="300" height="100" rx="8" fill="#111118" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
    <text x="170" y="368" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="19" fill="#f9fafb">Clawdius</text>
    <text x="170" y="390" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#a0a0b0">Content Production Agent</text>
    <text x="170" y="410" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#6b6b7b">Series, commentary &amp; KB entries</text>

    <!-- Arrow down -->
    <line x1="170" y1="430" x2="170" y2="484" stroke="#d4a853" stroke-width="1.5" stroke-dasharray="6 4" marker-end="url(#arrow-mobile)" opacity="0.6" />
    <text x="190" y="462" font-family="Inter, sans-serif" font-size="11" fill="#d4a853" opacity="0.8">produces content</text>

    <!-- Easy Markdown -->
    <rect x="20" y="490" width="300" height="100" rx="8" fill="#111118" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
    <text x="170" y="528" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="19" fill="#f9fafb">Easy Markdown</text>
    <text x="170" y="550" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#a0a0b0">Content Processing</text>
    <text x="170" y="570" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#6b6b7b">Schema validation &amp; rendering</text>

    <!-- Lifecycle label -->
    <text x="170" y="640" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="13" fill="#6b6b7b" opacity="0.5">Agent Infrastructure Lifecycle</text>
  </svg>
</div>

<style>
  .ecosystem-map {
    width: 100%;
  }
  .ecosystem-svg {
    width: 100%;
    height: auto;
  }
  /* Show wide on md+, narrow on small screens */
  .ecosystem-svg--wide {
    display: none;
  }
  .ecosystem-svg--narrow {
    display: block;
  }
  @media (min-width: 768px) {
    .ecosystem-svg--wide {
      display: block;
    }
    .ecosystem-svg--narrow {
      display: none;
    }
  }
</style>
