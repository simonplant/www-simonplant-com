---
/**
 * GDPR-compliant cookie consent banner.
 * PostHog only loads after the user accepts.
 */
---

<div
  id="cookie-banner"
  ph-no-capture
  class="fixed bottom-0 left-0 right-0 z-50 hidden border-t border-border-default bg-surface-card p-4 shadow-lg"
>
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-3 sm:flex-row sm:justify-between">
    <p class="text-sm text-text-secondary">
      This site uses analytics cookies to understand how visitors interact with the website.
    </p>
    <div class="flex gap-2">
      <button
        id="cookie-reject"
        class="rounded border border-border-default px-4 py-1.5 text-sm text-text-secondary hover:bg-surface-elevated"
      >
        Decline
      </button>
      <button
        id="cookie-accept"
        class="rounded bg-primary-500 px-4 py-1.5 text-sm text-surface-bg hover:bg-primary-600"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<script>
  import { initSiteTracking } from '../lib/analytics';

  const CONSENT_KEY = 'analytics-consent';

  function getConsent(): string | null {
    return localStorage.getItem(CONSENT_KEY);
  }

  function setConsent(value: 'granted' | 'denied') {
    localStorage.setItem(CONSENT_KEY, value);
  }

  function loadPostHog() {
    import('posthog-js').then(({ default: posthog }) => {
      posthog.init(import.meta.env.PUBLIC_POSTHOG_KEY ?? '', {
        defaults: '2026-01-30',
        api_host: '/ingest',
        // ui_host must point at PostHog's real domain (not the proxy) so the
        // toolbar and in-app links resolve correctly when api_host is proxied.
        ui_host: 'https://us.posthog.com',
        persistence: 'localStorage+cookie',
        person_profiles: 'identified_only',
        autocapture: true,
        // Static MPA: navigations are full page loads, so capture on load
        // rather than the 'history_change' default newer `defaults` would set.
        capture_pageview: true,
        capture_pageleave: true,
        capture_dead_clicks: true,
        capture_performance: { web_vitals: true },
        enable_heatmaps: true,
        respect_dnt: true,
        session_recording: {
          maskAllInputs: true,
        },
        // Strip query strings from captured URLs so stray params never leak as
        // PII. UTM params are already parsed into their own properties upstream.
        before_send: (event) => {
          if (event?.properties) {
            for (const key of ['$current_url', '$referrer', '$pathname'] as const) {
              const value = event.properties[key];
              if (typeof value === 'string') {
                const q = value.indexOf('?');
                if (q !== -1) event.properties[key] = value.slice(0, q);
              }
            }
          }
          return event;
        },
        loaded: (ph) => {
          if (import.meta.env.DEV) ph.opt_out_capturing();
          initSiteTracking(ph);
        },
      });
    });
  }

  const banner = document.getElementById('cookie-banner')!;
  const consent = getConsent();

  if (consent === null) {
    banner.classList.remove('hidden');
  } else if (consent === 'granted') {
    loadPostHog();
  }

  document.getElementById('cookie-accept')!.addEventListener('click', () => {
    setConsent('granted');
    banner.classList.add('hidden');
    loadPostHog();
  });

  document.getElementById('cookie-reject')!.addEventListener('click', () => {
    setConsent('denied');
    banner.classList.add('hidden');
  });
</script>
