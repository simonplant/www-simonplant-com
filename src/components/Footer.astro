---
const year = new Date().getFullYear();

const navLinks = [
  { href: '/series', label: 'Series' },
  { href: '/commentary', label: 'Commentary' },
  { href: '/architecture', label: 'Architecture' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];
---

<footer class="border-t border-border-default mt-auto">
  <div class="container-wide py-8 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex flex-col gap-3">
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-5 gap-y-1 list-none m-0 p-0 text-sm">
          {navLinks.map(({ href, label }) => (
            <li class="m-0 p-0">
              <a href={href} class="text-text-secondary hover:text-text-primary no-underline transition-colors">
                {label}
              </a>
            </li>
          ))}
          <li class="m-0 p-0">
            <a href="/rss.xml" class="text-text-secondary hover:text-text-primary no-underline transition-colors">
              RSS
            </a>
          </li>
        </ul>
      </nav>
      <div class="text-sm text-text-muted">
        <a href="mailto:simon@simonplant.com" class="text-text-secondary hover:text-text-primary no-underline transition-colors">
          simon@simonplant.com
        </a>
      </div>
    </div>
    <p class="text-sm text-text-muted m-0">
      &copy; {year} Simon Plant
    </p>
  </div>
</footer>
