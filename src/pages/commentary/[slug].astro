---
import Base from '../../layouts/Base.astro';
import { getPublishedCollection } from '../../content/_helpers';
import { getReadingTime } from '../../utils/readingTime';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getPublishedCollection('commentary');
  const sorted = entries.sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());

  return sorted.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readingTime = getReadingTime(entry.body);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  url: canonicalUrl,
  datePublished: entry.data.publishedDate.toISOString(),
  author: { '@type': 'Person', name: 'Simon Plant' },
  keywords: entry.data.tags,
  wordCount,
};
---

<Base
  title={`${entry.data.title} — Simon Plant`}
  description={entry.data.description}
  ogType="article"
  articleDate={entry.data.publishedDate.toISOString()}
  articleTags={entry.data.tags}
  jsonLd={jsonLd}
>
  <main class="section-spacing">
    <article data-ph-capture-attribute-content-type="commentary" data-ph-capture-attribute-slug={entry.id}>
      <header class="container-prose mb-8">
        <a href="/commentary" class="text-text-muted text-sm font-sans hover:text-primary-400 transition-colors inline-flex items-center gap-1 mb-6">
          &larr; All commentary
        </a>
        <h1 class="font-serif text-4xl text-gray-50 leading-tight mb-4">{entry.data.title}</h1>
        <div class="flex flex-wrap gap-3 text-text-muted text-sm font-sans mb-4">
          <time datetime={entry.data.publishedDate.toISOString().slice(0, 10)}>
            {entry.data.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span>&middot;</span>
          <span>{readingTime}</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="text-primary-400 bg-primary-400/10 px-2.5 py-0.5 rounded-full text-xs font-sans hover:bg-primary-400/20 transition-colors">
              {tag}
            </a>
          ))}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      {(prev || next) && (
        <nav class="container-prose mt-16 pt-8 border-t border-border-default" aria-label="Commentary navigation">
          <div class="flex justify-between gap-4">
            {prev ? (
              <a href={`/commentary/${prev.id}`} class="group flex-1 min-w-0">
                <span class="text-text-muted text-sm font-sans block mb-1">&larr; Newer</span>
                <span class="text-gray-50 font-serif group-hover:text-primary-400 transition-colors line-clamp-2">
                  {prev.data.title}
                </span>
              </a>
            ) : <div />}
            {next ? (
              <a href={`/commentary/${next.id}`} class="group flex-1 min-w-0 text-right">
                <span class="text-text-muted text-sm font-sans block mb-1">Older &rarr;</span>
                <span class="text-gray-50 font-serif group-hover:text-primary-400 transition-colors line-clamp-2">
                  {next.data.title}
                </span>
              </a>
            ) : <div />}
          </div>
        </nav>
      )}
    </article>
  </main>

  <script is:inline>
    (function () {
      var prose = document.querySelector('.prose');
      if (!prose) return;

      var slug = document.querySelector('[data-ph-capture-attribute-slug]')?.getAttribute('data-ph-capture-attribute-slug') || '';
      var title = document.title.replace(' — Simon Plant', '');
      var fired = {};

      [25, 50, 75, 100].forEach(function (pct) {
        var sentinel = document.createElement('div');
        sentinel.style.height = '1px';
        sentinel.style.pointerEvents = 'none';
        sentinel.setAttribute('aria-hidden', 'true');
        sentinel.dataset.scrollDepth = String(pct);

        var children = Array.from(prose.children);
        var idx = Math.min(Math.floor((pct / 100) * children.length), children.length - 1);
        if (pct === 100) {
          prose.appendChild(sentinel);
        } else {
          prose.insertBefore(sentinel, children[idx]);
        }
      });

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var depth = entry.target.dataset.scrollDepth;
          if (fired[depth]) return;
          fired[depth] = true;
          if (window.__posthog) {
            window.__posthog.capture('article_scroll_depth', {
              slug: slug,
              depth_percent: Number(depth),
              title: title,
              content_type: 'commentary'
            });
          }
          observer.unobserve(entry.target);
        });
      }, { threshold: 0 });

      document.querySelectorAll('[data-scroll-depth]').forEach(function (el) {
        observer.observe(el);
      });
    })();
  </script>
</Base>
