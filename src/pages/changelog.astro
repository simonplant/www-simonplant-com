---
import Base from '../layouts/Base.astro';
import changelogData from '../data/changelog.json';

interface ChangelogEntry {
  date: string;
  description: string;
  link: string | null;
}

const entries: ChangelogEntry[] = (changelogData as ChangelogEntry[]).sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Changelog — Simon Plant',
  url: 'https://www.simonplant.com/changelog',
  description: 'What shipped, changed, or launched on simonplant.com.',
};
---

<Base title="Changelog — Simon Plant" description="What shipped, changed, or launched on simonplant.com." jsonLd={jsonLd}>
  <main class="section-spacing">
    <div class="prose">
      <h1>Changelog</h1>
      <p class="text-text-secondary">What shipped, changed, or launched — in reverse chronological order.</p>

      <ul class="changelog-list">
        {entries.map((entry) => (
          <li>
            <time datetime={entry.date}>
              {new Date(entry.date + 'T00:00:00').toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            {entry.link ? (
              <span>
                {entry.description} <a href={entry.link}>View →</a>
              </span>
            ) : (
              <span>{entry.description}</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </main>
</Base>

<style>
  .changelog-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
  }

  .changelog-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border-subtle);
    align-items: baseline;
  }

  .changelog-list li:last-child {
    border-bottom: none;
  }

  .changelog-list time {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-primary-400);
    white-space: nowrap;
  }

  .changelog-list span {
    color: var(--color-text-primary);
  }

  .changelog-list a {
    color: var(--color-primary-400);
    text-decoration: none;
    margin-left: 0.5rem;
  }

  .changelog-list a:hover {
    text-decoration: underline;
  }
</style>
