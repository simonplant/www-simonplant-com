---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const sorted = products.sort((a, b) => a.data.order - b.data.order);

const statusColors: Record<string, { bg: string; text: string }> = {
  active: { bg: 'bg-green-900/40', text: 'text-green-400' },
  beta: { bg: 'bg-yellow-900/40', text: 'text-yellow-400' },
  planned: { bg: 'bg-blue-900/40', text: 'text-blue-400' },
  stable: { bg: 'bg-emerald-900/40', text: 'text-emerald-400' },
};
---

<Base title="Products — Simon Plant" description="The agent infrastructure ecosystem — ClawHQ, AIShore, Easy Markdown, and Clawdius." jsonLd={{
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Products — Simon Plant',
  url: 'https://www.simonplant.com/products',
  description: 'The agent infrastructure ecosystem — ClawHQ, AIShore, Easy Markdown, and Clawdius.',
}}>
  <main class="section-spacing">
    <div class="container-wide">
      <div class="max-w-3xl mb-16">
        <h1 class="font-serif text-4xl text-gray-50 mb-4">Product Ecosystem</h1>
        <p class="text-text-secondary text-lg font-prose leading-relaxed">
          Four tools that form a complete agent infrastructure lifecycle — from sprint planning
          to code delivery, content production, and content validation. Each solves one problem well.
          Together, they demonstrate what production-grade AI agent systems look like.
        </p>
      </div>

      <!-- Relationship Map -->
      <div class="mb-16 bg-surface-card border border-border-subtle rounded-lg p-8">
        <h2 class="font-serif text-2xl text-gray-50 mb-6">How They Fit Together</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm font-sans">
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <span class="text-primary-400 font-mono text-xs mt-1 shrink-0">1.</span>
              <p class="text-text-secondary">
                <strong class="text-gray-50">AIShore</strong> grooms the backlog and orchestrates sprints — turning intent into structured work items with acceptance criteria.
              </p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-primary-400 font-mono text-xs mt-1 shrink-0">2.</span>
              <p class="text-text-secondary">
                <strong class="text-gray-50">ClawHQ</strong> manages agent lifecycles — dispatching, monitoring, and enforcing policy on the agents that do the work.
              </p>
            </div>
          </div>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <span class="text-primary-400 font-mono text-xs mt-1 shrink-0">3.</span>
              <p class="text-text-secondary">
                <strong class="text-gray-50">Clawdius</strong> is a managed agent — he produces content (series, commentary, KB entries) under strict editorial constraints.
              </p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-primary-400 font-mono text-xs mt-1 shrink-0">4.</span>
              <p class="text-text-secondary">
                <strong class="text-gray-50">Easy Markdown</strong> validates and renders the content Clawdius produces — schema enforcement, editorial workflow, type-safe frontmatter.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Product Grid -->
      {sorted.length === 0 ? (
        <p class="text-text-muted">No products listed yet. Check back soon.</p>
      ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sorted.map((product) => {
          const colors = statusColors[product.data.status] ?? statusColors.active;
          return (
            <a href={`/products/${product.id}`} class="group block bg-surface-card border border-border-subtle rounded-lg p-6 hover:border-primary-400/30 transition-colors">
              <div class="flex items-start justify-between gap-3 mb-3">
                <h2 class="font-serif text-2xl text-gray-50 group-hover:text-primary-400 transition-colors">
                  {product.data.title}
                </h2>
                <span class={`shrink-0 text-xs font-sans font-medium px-2 py-0.5 rounded ${colors.bg} ${colors.text}`}>
                  {product.data.status}
                </span>
              </div>
              <p class="text-primary-400/80 text-sm font-sans mb-3">{product.data.tagline}</p>
              <p class="text-text-secondary font-prose text-sm leading-relaxed mb-4">
                {product.data.description}
              </p>
              <div class="flex items-center justify-between">
                <span class="text-text-muted text-xs font-sans uppercase tracking-wider">
                  {product.data.role}
                </span>
                <span class="text-text-muted text-sm group-hover:text-primary-400 transition-colors">
                  &rarr;
                </span>
              </div>
            </a>
          );
        })}
      </div>
      )}
    </div>
  </main>
</Base>
