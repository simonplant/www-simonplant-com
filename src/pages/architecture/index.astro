---
import Base from '../../layouts/Base.astro';
import { getPublishedCollection } from '../../content/_helpers';

const entries = await getPublishedCollection('architecture');
const sorted = entries.sort((a, b) => a.data.title.localeCompare(b.data.title));

const allTags = [...new Set(sorted.flatMap((e) => e.data.tags))].sort();
---

<Base title="Architecture — Simon Plant" description="AI architecture patterns, decisions, and reference material — from someone building the management layer for AI agents in production." jsonLd={{
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Architecture — Simon Plant',
  url: 'https://www.simonplant.com/architecture',
  description: 'AI architecture patterns, decisions, and reference material — from someone building the management layer for AI agents in production.',
}}>
  <main class="section-spacing">
    <div class="container-prose">
      <h1 class="font-serif text-4xl text-gray-50 mb-4">Architecture</h1>
      <p class="text-text-secondary text-lg mb-8 font-prose">
        Patterns, decisions, and reference material from building AI agent infrastructure in production.
      </p>

      {allTags.length > 0 && (
        <nav class="mb-12 flex flex-wrap gap-2" aria-label="Filter by tag">
          <button
            data-tag=""
            class="tag-filter tag-active px-3 py-1 rounded-full text-sm font-sans border border-border-subtle transition-colors"
          >
            All
          </button>
          {allTags.map((tag) => (
            <button
              data-tag={tag}
              class="tag-filter px-3 py-1 rounded-full text-sm font-sans border border-border-subtle text-text-muted hover:text-primary-400 hover:border-primary-600 transition-colors"
            >
              {tag}
            </button>
          ))}
        </nav>
      )}

      {sorted.length === 0 ? (
        <p class="text-text-muted">Architecture entries are coming as patterns emerge from real builds.</p>
      ) : (
        <ol class="space-y-8 list-none p-0" id="arch-list">
          {sorted.map((entry) => (
            <li class="arch-item border-b border-border-subtle pb-8 last:border-b-0" data-tags={entry.data.tags.join(',')}>
              <a href={`/architecture/${entry.id}`} class="group block">
                <h2 class="font-serif text-2xl text-gray-50 mb-2 group-hover:text-primary-400 transition-colors">
                  {entry.data.title}
                </h2>
                <p class="text-text-secondary font-prose leading-relaxed mb-3">
                  {entry.data.description}
                </p>
                <div class="flex flex-wrap items-center gap-2 text-sm font-sans">
                  {entry.data.tags.map((tag) => (
                    <span class="text-primary-400 bg-primary-400/10 px-2 py-0.5 rounded-full text-xs">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </main>
</Base>

<style>
  .tag-active {
    color: var(--color-primary-400);
    border-color: var(--color-primary-600);
    background-color: color-mix(in srgb, var(--color-primary-400) 10%, transparent);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
    const items = document.querySelectorAll<HTMLLIElement>('.arch-item');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag ?? '';

        buttons.forEach((b) => b.classList.remove('tag-active'));
        btn.classList.add('tag-active');

        items.forEach((item) => {
          const itemTags = (item.dataset.tags ?? '').split(',');
          item.style.display = tag === '' || itemTags.includes(tag) ? '' : 'none';
        });
      });
    });
  });
</script>
