---
import Base from '../../layouts/Base.astro';
import { getPublishedCollection } from '../../content/_helpers';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getPublishedCollection('architecture');
  const sorted = entries.sort((a, b) => a.data.title.localeCompare(b.data.title));

  return sorted.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry.data.title,
  description: entry.data.description,
  url: canonicalUrl,
  author: { '@type': 'Person', name: 'Simon Plant' },
  keywords: entry.data.tags,
};
---

<Base
  title={`${entry.data.title} — Simon Plant`}
  description={entry.data.description}
  jsonLd={jsonLd}
>
  <main class="section-spacing">
    <article data-ph-capture-attribute-content-type="architecture" data-ph-capture-attribute-slug={entry.id}>
      <header class="container-prose mb-8">
        <a href="/architecture" class="text-text-muted text-sm font-sans hover:text-primary-400 transition-colors inline-flex items-center gap-1 mb-6">
          &larr; All architecture
        </a>
        <h1 class="font-serif text-4xl text-gray-50 leading-tight mb-4">{entry.data.title}</h1>
        <p class="text-text-secondary font-prose leading-relaxed mb-4">{entry.data.description}</p>
        <div class="flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <span class="text-primary-400 bg-primary-400/10 px-2.5 py-0.5 rounded-full text-xs font-sans">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      {(prev || next) && (
        <nav class="container-prose mt-16 pt-8 border-t border-border-default" aria-label="Architecture navigation">
          <div class="flex justify-between gap-4">
            {prev ? (
              <a href={`/architecture/${prev.id}`} class="group flex-1 min-w-0">
                <span class="text-text-muted text-sm font-sans block mb-1">&larr; Previous</span>
                <span class="text-gray-50 font-serif group-hover:text-primary-400 transition-colors line-clamp-2">
                  {prev.data.title}
                </span>
              </a>
            ) : <div />}
            {next ? (
              <a href={`/architecture/${next.id}`} class="group flex-1 min-w-0 text-right">
                <span class="text-text-muted text-sm font-sans block mb-1">Next &rarr;</span>
                <span class="text-gray-50 font-serif group-hover:text-primary-400 transition-colors line-clamp-2">
                  {next.data.title}
                </span>
              </a>
            ) : <div />}
          </div>
        </nav>
      )}
    </article>
  </main>
</Base>
