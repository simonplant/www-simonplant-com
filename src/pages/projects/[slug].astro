---
import Base from '../../layouts/Base.astro';
import PrevNext from '../../components/PrevNext.astro';
import { getCollection, render } from 'astro:content';
import { getStatusColors } from '../../utils/productStatus';

export async function getStaticPaths() {
  const products = await getCollection('products');
  const sorted = products.sort((a, b) => a.data.order - b.data.order);
  const titleMap = Object.fromEntries(products.map((p) => [p.id, p.data.title]));

  return sorted.map((product, index) => ({
    params: { slug: product.id },
    props: {
      product,
      titleMap,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { product, titleMap, prev, next } = Astro.props;
const { Content } = await render(product);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: product.data.title,
  description: product.data.description,
  url: canonicalUrl,
  applicationCategory: 'DeveloperApplication',
  author: { '@type': 'Person', name: 'Simon Plant' },
  ...(product.data.github && { codeRepository: product.data.github }),
};

const colors = getStatusColors(product.data.status);
---

<Base
  title={`${product.data.title} — Simon Plant`}
  description={product.data.description}
  jsonLd={jsonLd}
>
  <main class="section-spacing">
    <article data-pagefind-body>
      <header class="container-prose mb-8">
        <a href="/projects" class="text-text-muted text-sm font-sans hover:text-primary-400 transition-colors inline-flex items-center gap-1 mb-6">
          &larr; All projects
        </a>
        <div class="flex items-start gap-3 mb-2">
          <h1 class="font-serif text-4xl text-gray-50 leading-tight">{product.data.title}</h1>
          <span class={`shrink-0 text-xs font-sans font-medium px-2 py-0.5 rounded mt-2 ${colors.bg} ${colors.text}`}>
            {product.data.status}
          </span>
        </div>
        <p class="text-primary-400/80 text-lg font-sans mb-3">{product.data.tagline}</p>
        <p class="text-text-secondary font-prose leading-relaxed mb-4">
          {product.data.description}
        </p>
        <div class="flex flex-wrap gap-4 text-sm font-sans text-text-muted">
          <span class="uppercase tracking-wider">{product.data.role}</span>
          {product.data.github && (
            <>
              <span>&middot;</span>
              <a href={product.data.github} data-github-link class="text-primary-400 hover:text-primary-300 transition-colors">
                GitHub
              </a>
            </>
          )}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      {product.data.tags.length > 0 && (
        <div class="container-prose mt-8">
          <div class="flex flex-wrap gap-2">
            {product.data.tags.map((tag) => (
              <span class="text-xs font-sans bg-surface-elevated text-text-muted px-2.5 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      {product.data.relatedProducts && product.data.relatedProducts.length > 0 && (
        <aside class="container-prose mt-12">
          <h2 class="font-serif text-xl text-gray-50 mb-4">Related Products</h2>
          <div class="flex flex-wrap gap-3">
            {product.data.relatedProducts.map((slug) => (
              <a href={`/projects/${slug}`} class="text-primary-400 hover:text-primary-300 transition-colors underline underline-offset-2 text-sm font-sans">
                {titleMap[slug] ?? slug}
              </a>
            ))}
          </div>
        </aside>
      )}

      <PrevNext
        ariaLabel="Product navigation"
        prev={prev ? { href: `/projects/${prev.id}`, title: prev.data.title } : null}
        next={next ? { href: `/projects/${next.id}`, title: next.data.title } : null}
      />
    </article>
  </main>
</Base>

<script is:inline define:vars={{ githubUrl: product.data.github ?? null, projectTitle: product.data.title }}>
  if (githubUrl) {
    document.querySelector('[data-github-link]')?.addEventListener('click', function () {
      if (window.phCapture) {
        window.phCapture('project_github_click', { project: projectTitle, github_url: githubUrl });
      }
    });
  }
</script>
