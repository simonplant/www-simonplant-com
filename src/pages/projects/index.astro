---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const sorted = products.sort((a, b) => a.data.order - b.data.order);
const current = sorted.filter((p) => p.data.status !== 'archived');
const retired = sorted.filter((p) => p.data.status === 'archived');

const description =
  'AI systems I run in production and tools I build — from an advisory trading agent to an open-source markdown editor.';
---

<Base title="Projects — Simon Plant" description={description} jsonLd={{
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Projects — Simon Plant',
  url: new URL('/projects', Astro.site).href,
  description,
}}>
  <main class="section-spacing">
    <div class="container-wide">
      <div class="max-w-3xl mb-16">
        <h1 class="font-serif text-4xl text-gray-50 mb-4">Projects</h1>
        <p class="text-text-secondary text-lg font-prose leading-relaxed">
          Systems I build and run — some open-source, some private with the architecture shared.
        </p>
      </div>

      {current.length === 0 ? (
        <p class="text-text-muted">No projects listed yet.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {current.map((product) => <ProductCard product={product} />)}
        </div>
      )}

      {retired.length > 0 && (
        <section class="mt-20">
          <div class="max-w-3xl mb-8">
            <h2 class="font-serif text-3xl text-gray-50 mb-3">The journey</h2>
            <p class="text-text-secondary font-prose leading-relaxed">
              Tools I built, learned from, and deliberately retired. This space moves fast enough
              that retiring your own tools is a skill — each of these taught something that now
              lives inside what I run today.
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {retired.map((product) => <ProductCard product={product} />)}
          </div>
        </section>
      )}
    </div>
  </main>
</Base>
