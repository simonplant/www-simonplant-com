---
import Base from '../../layouts/Base.astro';
import CompanionArtifact from '../../components/CompanionArtifact.astro';
import { getPublishedCollection } from '../../content/_helpers';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getPublishedCollection('series');
  const sorted = entries.sort((a, b) => a.data.number - b.data.number);

  return sorted.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const wordCount = entry.body ? entry.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 230));

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry.data.title,
  description: entry.data.description,
  url: canonicalUrl,
  datePublished: entry.data.publishedDate.toISOString(),
  author: { '@type': 'Person', name: 'Simon Plant' },
  keywords: entry.data.tags,
  wordCount,
};
---

<Base
  title={`${entry.data.title} — Simon Plant`}
  description={entry.data.description}
  ogType="article"
  articleDate={entry.data.publishedDate.toISOString()}
  articleTags={entry.data.tags}
  jsonLd={jsonLd}
>
  <main class="section-spacing">
    <article data-ph-capture-attribute-content-type="series" data-ph-capture-attribute-slug={entry.id}>
      <header class="container-prose mb-8">
        <a href="/series" class="text-text-muted text-sm font-sans hover:text-primary-400 transition-colors inline-flex items-center gap-1 mb-6">
          &larr; All installments
        </a>
        <p class="text-text-muted text-sm font-sans uppercase tracking-wider mb-2">
          Installment {entry.data.number}
        </p>
        <h1 class="font-serif text-4xl text-gray-50 leading-tight mb-4">{entry.data.title}</h1>
        <div class="flex flex-wrap gap-3 text-text-muted text-sm font-sans mb-4">
          <time datetime={entry.data.publishedDate.toISOString().slice(0, 10)}>
            {entry.data.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span>&middot;</span>
          <span>{readingTime} min read</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="text-primary-400 bg-primary-400/10 px-2.5 py-0.5 rounded-full text-xs font-sans hover:bg-primary-400/20 transition-colors">
              {tag}
            </a>
          ))}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      {entry.data.companionArtifacts && entry.data.companionArtifacts.length > 0 && (
        <aside class="container-prose mt-12">
          <h2 class="font-serif text-xl text-gray-50 mb-4">Companion Artifacts</h2>
          <div class="space-y-3">
            {entry.data.companionArtifacts.map((artifact) => (
              <CompanionArtifact
                title={artifact.title}
                type={artifact.type}
                description={artifact.description}
                githubUrl={artifact.githubUrl}
              />
            ))}
          </div>
        </aside>
      )}

      {(prev || next) && (
        <nav class="container-prose mt-16 pt-8 border-t border-border-default" aria-label="Series navigation">
          <div class="flex justify-between gap-4">
            {prev ? (
              <a href={`/series/${prev.id}`} class="group flex-1 min-w-0">
                <span class="text-text-muted text-sm font-sans block mb-1">&larr; Previous</span>
                <span class="text-gray-50 font-serif group-hover:text-primary-400 transition-colors line-clamp-2">
                  {prev.data.title}
                </span>
              </a>
            ) : <div />}
            {next ? (
              <a href={`/series/${next.id}`} class="group flex-1 min-w-0 text-right">
                <span class="text-text-muted text-sm font-sans block mb-1">Next &rarr;</span>
                <span class="text-gray-50 font-serif group-hover:text-primary-400 transition-colors line-clamp-2">
                  {next.data.title}
                </span>
              </a>
            ) : <div />}
          </div>
        </nav>
      )}

      <aside class="container-prose mt-16 pt-8 border-t border-border-default">
        <div class="bg-surface-card rounded-lg p-6 text-center">
          <h2 class="font-serif text-xl text-gray-50 mb-2">Follow the series</h2>
          <p class="text-text-secondary font-prose mb-4">
            Get notified when new installments ship. No spam, no fluff — just the next chapter.
          </p>
          <a href="mailto:simon@simonplant.com?subject=Subscribe%20to%20Series" class="inline-block bg-primary-600 hover:bg-primary-500 text-white font-sans text-sm font-medium px-6 py-2.5 rounded-lg transition-colors" data-newsletter-cta>
            Subscribe
          </a>
        </div>
      </aside>
    </article>
  </main>

  <script is:inline>
    (function () {
      var prose = document.querySelector('.prose');
      if (!prose) return;

      var slug = document.querySelector('[data-ph-capture-attribute-slug]')?.getAttribute('data-ph-capture-attribute-slug') || '';
      var title = document.title.replace(' — Simon Plant', '');
      var fired = {};

      [25, 50, 75, 100].forEach(function (pct) {
        var sentinel = document.createElement('div');
        sentinel.style.height = '1px';
        sentinel.style.pointerEvents = 'none';
        sentinel.setAttribute('aria-hidden', 'true');
        sentinel.dataset.scrollDepth = String(pct);

        var children = Array.from(prose.children);
        var idx = Math.min(Math.floor((pct / 100) * children.length), children.length - 1);
        if (pct === 100) {
          prose.appendChild(sentinel);
        } else {
          prose.insertBefore(sentinel, children[idx]);
        }
      });

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var depth = entry.target.dataset.scrollDepth;
          if (fired[depth]) return;
          fired[depth] = true;
          if (window.__posthog) {
            window.__posthog.capture('article_scroll_depth', {
              slug: slug,
              depth_percent: Number(depth),
              title: title,
              content_type: 'series'
            });
          }
          observer.unobserve(entry.target);
        });
      }, { threshold: 0 });

      document.querySelectorAll('[data-scroll-depth]').forEach(function (el) {
        observer.observe(el);
      });

      // Newsletter CTA tracking
      var cta = document.querySelector('[data-newsletter-cta]');
      if (cta) {
        cta.addEventListener('click', function () {
          if (window.__posthog) {
            window.__posthog.capture('newsletter_cta_clicked', {
              source_page: window.location.pathname
            });
          }
        });
      }
    })();
  </script>
</Base>
