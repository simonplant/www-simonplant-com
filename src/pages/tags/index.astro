---
import Base from '../../layouts/Base.astro';
import { getPublishedCollection } from '../../content/_helpers';

const [seriesEntries, commentaryEntries, architectureEntries] = await Promise.all([
  getPublishedCollection('series'),
  getPublishedCollection('commentary'),
  getPublishedCollection('architecture'),
]);

type TagInfo = { count: number; series: number; commentary: number; architecture: number };
const tagMap = new Map<string, TagInfo>();

function countTags(entries: { data: { tags: string[] } }[], track: 'series' | 'commentary' | 'architecture') {
  for (const entry of entries) {
    for (const tag of entry.data.tags) {
      const info = tagMap.get(tag) ?? { count: 0, series: 0, commentary: 0, architecture: 0 };
      info.count++;
      info[track]++;
      tagMap.set(tag, info);
    }
  }
}

countTags(seriesEntries, 'series');
countTags(commentaryEntries, 'commentary');
countTags(architectureEntries, 'architecture');

const sortedTags = [...tagMap.entries()].sort((a, b) => b[1].count - a[1].count);
---

<Base title="Tags — Simon Plant" description="Browse all topics across series, commentary, and architecture knowledge base.">
  <main class="section-spacing">
    <div class="container-prose">
      <h1 class="font-serif text-4xl text-gray-50 leading-tight mb-4">Tags</h1>
      <p class="text-text-secondary font-prose mb-12">
        Topics across series, commentary, and architecture entries.
      </p>

      {sortedTags.length > 0 ? (
        <div class="flex flex-wrap gap-3">
          {sortedTags.map(([tag, info]) => (
            <a
              href={`/tags/${encodeURIComponent(tag)}`}
              class="group flex items-center gap-2 bg-surface-card hover:bg-surface-elevated border border-border-subtle hover:border-primary-600 rounded-lg px-4 py-2.5 transition-colors"
            >
              <span class="text-primary-400 font-sans text-sm group-hover:text-primary-300 transition-colors">
                {tag}
              </span>
              <span class="text-text-muted text-xs font-sans bg-surface-elevated group-hover:bg-surface-card px-2 py-0.5 rounded-full transition-colors">
                {info.count}
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-text-muted font-sans">No tagged content yet.</p>
      )}
    </div>
  </main>
</Base>
