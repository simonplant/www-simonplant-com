---
import Base from '../../layouts/Base.astro';
import { getPublishedCollection } from '../../content/_helpers';

export async function getStaticPaths() {
  const [seriesEntries, commentaryEntries, architectureEntries] = await Promise.all([
    getPublishedCollection('series'),
    getPublishedCollection('commentary'),
    getPublishedCollection('architecture'),
  ]);

  const tagMap = new Map<string, {
    series: typeof seriesEntries;
    commentary: typeof commentaryEntries;
    architecture: typeof architectureEntries;
  }>();

  for (const entry of seriesEntries) {
    for (const tag of entry.data.tags) {
      const group = tagMap.get(tag) ?? { series: [], commentary: [], architecture: [] };
      group.series.push(entry);
      tagMap.set(tag, group);
    }
  }
  for (const entry of commentaryEntries) {
    for (const tag of entry.data.tags) {
      const group = tagMap.get(tag) ?? { series: [], commentary: [], architecture: [] };
      group.commentary.push(entry);
      tagMap.set(tag, group);
    }
  }
  for (const entry of architectureEntries) {
    for (const tag of entry.data.tags) {
      const group = tagMap.get(tag) ?? { series: [], commentary: [], architecture: [] };
      group.architecture.push(entry);
      tagMap.set(tag, group);
    }
  }

  return [...tagMap.entries()].map(([tag, groups]) => ({
    params: { tag },
    props: {
      tag,
      series: groups.series.sort((a, b) => a.data.number - b.data.number),
      commentary: groups.commentary.sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()),
      architecture: groups.architecture.sort((a, b) => a.data.title.localeCompare(b.data.title)),
    },
  }));
}

const { tag, series, commentary, architecture } = Astro.props;
const totalCount = series.length + commentary.length + architecture.length;
---

<Base title={`${tag} — Simon Plant`} description={`Content tagged "${tag}" across series, commentary, and architecture.`}>
  <main class="section-spacing">
    <div class="container-prose">
      <a href="/tags" class="text-text-muted text-sm font-sans hover:text-primary-400 transition-colors inline-flex items-center gap-1 mb-6">
        &larr; All tags
      </a>
      <h1 class="font-serif text-4xl text-gray-50 leading-tight mb-2">{tag}</h1>
      <p class="text-text-muted font-sans mb-12">
        {totalCount} {totalCount === 1 ? 'entry' : 'entries'} across {
          [series.length > 0 && 'series', commentary.length > 0 && 'commentary', architecture.length > 0 && 'architecture']
            .filter(Boolean)
            .join(', ')
        }
      </p>

      {series.length > 0 && (
        <section class="mb-12">
          <h2 class="font-serif text-2xl text-gray-50 mb-6">Series</h2>
          <ul class="space-y-6">
            {series.map((entry) => (
              <li class="border-b border-border-subtle pb-6 last:border-b-0">
                <a href={`/series/${entry.id}`} class="group block">
                  <span class="text-text-muted text-sm font-sans uppercase tracking-wider">
                    Installment {entry.data.number}
                  </span>
                  <h3 class="font-serif text-xl text-gray-50 group-hover:text-primary-400 transition-colors mt-1">
                    {entry.data.title}
                  </h3>
                  <p class="text-text-secondary font-prose text-sm mt-2 line-clamp-2">
                    {entry.data.description}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {commentary.length > 0 && (
        <section class="mb-12">
          <h2 class="font-serif text-2xl text-gray-50 mb-6">Commentary</h2>
          <ul class="space-y-6">
            {commentary.map((entry) => (
              <li class="border-b border-border-subtle pb-6 last:border-b-0">
                <a href={`/commentary/${entry.id}`} class="group block">
                  <time class="text-text-muted text-sm font-sans" datetime={entry.data.publishedDate.toISOString().slice(0, 10)}>
                    {entry.data.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <h3 class="font-serif text-xl text-gray-50 group-hover:text-primary-400 transition-colors mt-1">
                    {entry.data.title}
                  </h3>
                  <p class="text-text-secondary font-prose text-sm mt-2 line-clamp-2">
                    {entry.data.description}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {architecture.length > 0 && (
        <section class="mb-12">
          <h2 class="font-serif text-2xl text-gray-50 mb-6">Architecture</h2>
          <ul class="space-y-6">
            {architecture.map((entry) => (
              <li class="border-b border-border-subtle pb-6 last:border-b-0">
                <a href={`/architecture/${entry.id}`} class="group block">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-text-muted text-xs font-sans bg-surface-elevated px-2 py-0.5 rounded">{entry.data.concern}</span>
                    <span class="text-text-muted text-xs font-sans bg-surface-elevated px-2 py-0.5 rounded">{entry.data.patternType}</span>
                  </div>
                  <h3 class="font-serif text-xl text-gray-50 group-hover:text-primary-400 transition-colors">
                    {entry.data.title}
                  </h3>
                  <p class="text-text-secondary font-prose text-sm mt-2 line-clamp-2">
                    {entry.data.description}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </main>
</Base>
