---
import Base from '../layouts/Base.astro';
import { getPublishedCollection } from '../content/_helpers';
import { getReadingTime } from '../utils/readingTime';
import { formatDate, isoDate } from '../utils/formatDate';
import { getCollection } from 'astro:content';

const entries = await getPublishedCollection('commentary');
const latestPosts = entries
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime())
  .slice(0, 3);

const products = (await getCollection('products'))
  .filter((p) => p.data.status !== 'archived')
  .sort((a, b) => a.data.order - b.data.order);

const description =
  'Fractional CTO. Thirty years building the management layer around new infrastructure — from early AWS to AI agents in production.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Simon Plant',
  url: new URL('/', Astro.site).href,
  description,
  author: {
    '@type': 'Person',
    name: 'Simon Plant',
  },
};
---

<Base title="Simon Plant" description={description} jsonLd={jsonLd}>
  <main class="section-spacing">
    <div class="container-prose">

      <!-- Masthead -->
      <header class="mb-16">
        <h1 class="font-serif text-5xl md:text-6xl text-gray-50 mb-4">Simon Plant</h1>
        <p class="font-prose text-xl md:text-2xl text-text-secondary leading-relaxed">
          {description}
        </p>
      </header>

      <!-- Latest writing -->
      <section class="mb-16">
        {latestPosts.length > 0 ? (
          <div class="space-y-8">
            {latestPosts.map((entry) => (
              <a href={`/blog/${entry.id}`} class="group block border-b border-border-subtle pb-8 last:border-b-0">
                <h2 class="font-serif text-2xl text-gray-50 mb-2 group-hover:text-primary-400 transition-colors">
                  {entry.data.title}
                </h2>
                <p class="text-text-secondary font-prose leading-relaxed mb-2">
                  {entry.data.description}
                </p>
                <div class="flex flex-wrap items-center gap-2 text-sm font-sans">
                  <time class="text-text-muted" datetime={isoDate(entry.data.publishedDate)}>
                    {formatDate(entry.data.publishedDate)}
                  </time>
                  <span class="text-text-muted">&middot;</span>
                  <span class="text-text-muted">{getReadingTime(entry.body)}</span>
                </div>
              </a>
            ))}
            <a href="/blog" class="inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors">
              All posts &rarr;
            </a>
          </div>
        ) : (
          <p class="text-text-muted font-prose">New writing is on the way.</p>
        )}
      </section>

      <!-- What I'm building -->
      {products.length > 0 && (
        <section class="mb-16">
          <h2 class="font-serif text-2xl text-gray-50 mb-3">What I'm building</h2>
          <p class="font-prose text-text-secondary leading-relaxed mb-6">
            The advice is grounded in shipping — AI systems I run in production and tools I build.
          </p>
          <ul class="space-y-3 list-none p-0 m-0">
            {products.map((product) => (
              <li class="m-0 p-0">
                <a href={`/projects/${product.id}`} class="group font-sans text-sm no-underline">
                  <span class="text-primary-400 group-hover:text-primary-300 font-medium transition-colors">
                    {product.data.title}
                  </span>
                  <span class="text-text-secondary"> — {product.data.tagline}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Contact CTA -->
      <aside class="border-t border-border-default pt-8">
        <p class="font-prose text-text-secondary mb-3">
          Working through a hard technology decision? That's the conversation I want to have.
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-1">
          <a
            href="/services"
            class="inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors"
          >
            Fractional CTO services &rarr;
          </a>
          <a
            href="mailto:website@simonplant.com"
            class="inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors"
          >
            website@simonplant.com &rarr;
          </a>
        </div>
      </aside>

    </div>
  </main>
</Base>
