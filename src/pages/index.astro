---
import Base from '../layouts/Base.astro';
import { getPublishedCollection } from '../content/_helpers';

const seriesEntries = await getPublishedCollection('series');
const commentaryEntries = await getPublishedCollection('commentary');

const latestSeries = seriesEntries
  .sort((a, b) => b.data.number - a.data.number)[0] ?? null;

const latestCommentary = commentaryEntries
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime())[0] ?? null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Simon Plant',
  url: 'https://www.simonplant.com',
  description: 'Simon Plant — AI infrastructure architect. Building the ops layer for production agent systems.',
  author: {
    '@type': 'Person',
    name: 'Simon Plant',
  },
};
---

<Base
  title="Simon Plant"
  description="AI infrastructure architect. Building the ops layer for production agent systems."
  jsonLd={jsonLd}
>
  <main class="section-spacing">
    <div class="container-prose">

      <!-- Masthead -->
      <header class="mb-16">
        <h1 class="font-serif text-5xl md:text-6xl text-gray-50 mb-4">Simon Plant</h1>
        <p class="font-prose text-xl md:text-2xl text-text-secondary leading-relaxed">
          Building the infrastructure layer that turns AI agents from demos into production systems.
        </p>
      </header>

      <!-- Three paths -->
      <nav class="mb-16 space-y-6" aria-label="Content paths">
        <a href="/series" class="group block border-b border-border-subtle pb-6">
          <h2 class="font-serif text-2xl text-gray-50 group-hover:text-primary-400 transition-colors mb-1">The Series</h2>
          <p class="text-text-secondary font-prose">The full arc — from scripts to production agent systems. Long-form installments mapping each stage of infrastructure maturation.</p>
        </a>
        <a href="/products" class="group block border-b border-border-subtle pb-6">
          <h2 class="font-serif text-2xl text-gray-50 group-hover:text-primary-400 transition-colors mb-1">Products</h2>
          <p class="text-text-secondary font-prose">The tools I build and run — agent orchestration, deployment, content pipelines. Real software solving real problems.</p>
        </a>
        <a href="/commentary" class="group block border-b border-border-subtle pb-6">
          <h2 class="font-serif text-2xl text-gray-50 group-hover:text-primary-400 transition-colors mb-1">Commentary</h2>
          <p class="text-text-secondary font-prose">Short-form takes on what's happening in AI infrastructure — supply chain attacks, agent security, deployment patterns, and the decisions that shape production systems.</p>
        </a>
      </nav>

      <!-- Latest content -->
      <section class="mb-16 space-y-10">

        {latestSeries && (
          <div>
            <h3 class="font-sans text-sm uppercase tracking-wider text-text-muted mb-3">Latest from the series</h3>
            <a href={`/series/${latestSeries.id}`} class="group block">
              <span class="text-text-muted text-sm font-sans">Installment {latestSeries.data.number}</span>
              <h4 class="font-serif text-xl text-gray-50 group-hover:text-primary-400 transition-colors mt-1 mb-2">
                {latestSeries.data.title}
              </h4>
              <p class="text-text-secondary font-prose text-base leading-relaxed">
                {latestSeries.data.description}
              </p>
            </a>
          </div>
        )}

        {latestCommentary && (
          <div>
            <h3 class="font-sans text-sm uppercase tracking-wider text-text-muted mb-3">Latest commentary</h3>
            <a href={`/commentary/${latestCommentary.id}`} class="group block">
              <h4 class="font-serif text-xl text-gray-50 group-hover:text-primary-400 transition-colors mb-2">
                {latestCommentary.data.title}
              </h4>
              <p class="text-text-secondary font-prose text-base leading-relaxed mb-1">
                {latestCommentary.data.description}
              </p>
              <span class="text-text-muted text-sm font-sans">
                {latestCommentary.data.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </a>
          </div>
        )}

        {!latestSeries && !latestCommentary && (
          <p class="text-text-muted font-prose">New writing is on the way. Check back soon.</p>
        )}

      </section>

      <!-- Subscribe CTA -->
      <aside class="border-t border-border-default pt-8">
        <p class="font-prose text-text-secondary mb-3">
          Follow along as I document what it takes to run AI agents in production.
        </p>
        <a
          href="/newsletter"
          class="inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors"
        >
          Subscribe to the newsletter &rarr;
        </a>
      </aside>

    </div>
  </main>
</Base>
