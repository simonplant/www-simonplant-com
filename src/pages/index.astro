---
import Base from '../layouts/Base.astro';
import { getPublishedCollection } from '../content/_helpers';
import { getReadingTime } from '../utils/readingTime';
import { formatDate, isoDate } from '../utils/formatDate';
import { getCollection } from 'astro:content';

const posts = (await getPublishedCollection('commentary'))
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime())
  .slice(0, 3);

const patterns = (await getPublishedCollection('architecture'))
  .sort((a, b) => (b.data.publishedDate?.getTime() ?? 0) - (a.data.publishedDate?.getTime() ?? 0))
  .slice(0, 3);

const securityEntries = (await getPublishedCollection('security'))
  .sort((a, b) => (b.data.publishedDate?.getTime() ?? 0) - (a.data.publishedDate?.getTime() ?? 0))
  .slice(0, 3);

const products = (await getCollection('products'))
  .filter((p) => p.data.status !== 'archived')
  .sort((a, b) => a.data.order - b.data.order);

const description =
  'Chief architect turned fractional CTO. Thirty years designing and delivering the systems each new platform makes possible — web, cloud, DevOps, now AI. Hands-on in the code, and at the leadership table.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Simon Plant',
  url: new URL('/', Astro.site).href,
  description,
  author: {
    '@type': 'Person',
    name: 'Simon Plant',
  },
};
---

<Base title="Simon Plant" description={description} jsonLd={jsonLd}>
  <main class="section-spacing">
    <div class="container-prose">

      <!-- Who I am -->
      <header class="mb-16">
        <h1 class="font-serif text-5xl md:text-6xl text-gray-50 mb-4">Simon Plant</h1>
        <p class="font-prose text-xl md:text-2xl text-text-secondary leading-relaxed">
          {description}
        </p>
      </header>

      <!-- What I do for you -->
      <section class="mb-16">
        <h2 class="font-serif text-2xl text-gray-50 mb-3">What I do</h2>
        <p class="font-prose text-text-secondary leading-relaxed mb-4">
          I work with 2–3 companies at a time as a fractional CTO — AI reality checks, architecture
          strategy, executive advisory, and turning strategic bets into executable delivery plans.
          If you're facing a technology decision where getting it wrong is expensive, that's my job.
        </p>
        <a href="/services" class="inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors">
          Fractional CTO services &rarr;
        </a>
      </section>

      <!-- AI architecture patterns -->
      {patterns.length > 0 && (
        <section class="mb-16">
          <h2 class="font-serif text-2xl text-gray-50 mb-3">AI architecture patterns</h2>
          <p class="font-prose text-text-secondary leading-relaxed mb-6">
            A working reference for designing and operating AI systems — patterns, decisions, and
            trade-offs written from production experience, not theory.
          </p>
          <div class="space-y-6">
            {patterns.map((entry) => (
              <a href={`/architecture/${entry.id}`} class="group block border-b border-border-subtle pb-6 last:border-b-0">
                <h3 class="font-serif text-xl text-gray-50 mb-1 group-hover:text-primary-400 transition-colors">
                  {entry.data.title}
                </h3>
                <p class="text-text-secondary font-prose text-sm leading-relaxed">
                  {entry.data.description}
                </p>
              </a>
            ))}
          </div>
          <a href="/architecture" class="mt-6 inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors">
            All patterns &rarr;
          </a>
        </section>
      )}

      <!-- AI security -->
      {securityEntries.length > 0 && (
        <section class="mb-16">
          <h2 class="font-serif text-2xl text-gray-50 mb-3">AI security</h2>
          <p class="font-prose text-text-secondary leading-relaxed mb-6">
            How AI systems get attacked and how to defend them — techniques, hardening, and
            advisories from running hardened agents in production.
          </p>
          <div class="space-y-6">
            {securityEntries.map((entry) => (
              <a href={`/security/${entry.id}`} class="group block border-b border-border-subtle pb-6 last:border-b-0">
                <h3 class="font-serif text-xl text-gray-50 mb-1 group-hover:text-primary-400 transition-colors">
                  {entry.data.title}
                </h3>
                <p class="text-text-secondary font-prose text-sm leading-relaxed">
                  {entry.data.description}
                </p>
              </a>
            ))}
          </div>
          <a href="/security" class="mt-6 inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors">
            All security entries &rarr;
          </a>
        </section>
      )}

      <!-- What I'm building -->
      {products.length > 0 && (
        <section class="mb-16">
          <h2 class="font-serif text-2xl text-gray-50 mb-3">What I'm building</h2>
          <p class="font-prose text-text-secondary leading-relaxed mb-6">
            The advice is grounded in shipping — AI systems I run in production and tools I build.
          </p>
          <ul class="space-y-3 list-none p-0 m-0">
            {products.map((product) => (
              <li class="m-0 p-0">
                <a href={`/projects/${product.id}`} class="group font-sans text-sm no-underline">
                  <span class="text-primary-400 group-hover:text-primary-300 font-medium transition-colors">
                    {product.data.title}
                  </span>
                  <span class="text-text-secondary"> — {product.data.tagline}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Writing -->
      {posts.length > 0 && (
        <section class="mb-16">
          <h2 class="font-serif text-2xl text-gray-50 mb-6">Writing</h2>
          <ul class="space-y-3 list-none p-0 m-0">
            {posts.map((entry) => (
              <li class="m-0 p-0 flex flex-wrap items-baseline gap-x-3">
                <a href={`/blog/${entry.id}`} class="font-serif text-lg text-gray-50 hover:text-primary-400 transition-colors no-underline">
                  {entry.data.title}
                </a>
                <span class="text-text-muted text-sm font-sans">
                  <time datetime={isoDate(entry.data.publishedDate)}>{formatDate(entry.data.publishedDate)}</time>
                  &nbsp;&middot;&nbsp;{getReadingTime(entry.body)}
                </span>
              </li>
            ))}
          </ul>
          <a href="/blog" class="mt-6 inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors">
            All posts &rarr;
          </a>
        </section>
      )}

      <!-- Contact CTA -->
      <aside class="border-t border-border-default pt-8">
        <p class="font-prose text-text-secondary mb-3">
          Working through a hard technology decision? That's the conversation I want to have.
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-1">
          <a
            href="/services"
            class="inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors"
          >
            Fractional CTO services &rarr;
          </a>
          <a
            href="mailto:website@simonplant.com"
            class="inline-block font-sans text-sm font-medium text-primary-400 hover:text-primary-300 transition-colors"
          >
            website@simonplant.com &rarr;
          </a>
        </div>
      </aside>

    </div>
  </main>
</Base>
