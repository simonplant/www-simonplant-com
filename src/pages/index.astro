---
import Base from '../layouts/Base.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Simon Plant',
  url: 'https://www.simonplant.com',
  description: 'Simon Plant — AI infrastructure architect. Building the ops layer for production agent systems.',
  author: {
    '@type': 'Person',
    name: 'Simon Plant',
  },
};
---

<Base
  title="Simon Plant"
  description="AI infrastructure architect. Building the ops layer for production agent systems."
  jsonLd={jsonLd}
>
  <main class="flex min-h-screen items-center justify-center">
    <h1 class="font-serif text-4xl text-primary">Simon Plant</h1>
  </main>
</Base>
