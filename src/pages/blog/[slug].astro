---
import Base from '../../layouts/Base.astro';
import ScrollDepth from '../../components/ScrollDepth.astro';
import PrevNext from '../../components/PrevNext.astro';
import { getPublishedCollection } from '../../content/_helpers';
import { getReadingTime } from '../../utils/readingTime';
import { formatDate, isoDate } from '../../utils/formatDate';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getPublishedCollection('commentary');
  const sorted = entries.sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());

  return sorted.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readingTime = getReadingTime(entry.body);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  url: canonicalUrl,
  datePublished: entry.data.publishedDate.toISOString(),
  author: { '@type': 'Person', name: 'Simon Plant' },
  keywords: entry.data.tags,
  wordCount,
};
---

<Base
  title={`${entry.data.title} — Simon Plant`}
  description={entry.data.description}
  ogType="article"
  articleDate={entry.data.publishedDate.toISOString()}
  articleTags={entry.data.tags}
  jsonLd={jsonLd}
>
  <main class="section-spacing">
    <article data-ph-capture-attribute-content-type="blog" data-ph-capture-attribute-slug={entry.id}>
      <header class="container-prose mb-8">
        <a href="/blog" class="text-text-muted text-sm font-sans hover:text-primary-400 transition-colors inline-flex items-center gap-1 mb-6">
          &larr; All posts
        </a>
        <h1 class="font-serif text-4xl text-gray-50 leading-tight mb-4">{entry.data.title}</h1>
        <div class="flex flex-wrap gap-3 text-text-muted text-sm font-sans mb-4">
          <time datetime={isoDate(entry.data.publishedDate)}>
            {formatDate(entry.data.publishedDate)}
          </time>
          <span>&middot;</span>
          <span>{readingTime}</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <span class="text-primary-400 bg-primary-400/10 px-2.5 py-0.5 rounded-full text-xs font-sans">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      <PrevNext
        ariaLabel="Post navigation"
        prevLabel="Newer"
        nextLabel="Older"
        prev={prev ? { href: `/blog/${prev.id}`, title: prev.data.title } : null}
        next={next ? { href: `/blog/${next.id}`, title: next.data.title } : null}
      />
    </article>
  </main>

  <ScrollDepth contentType="blog" />
</Base>
