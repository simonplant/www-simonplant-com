---
import Base from '../../layouts/Base.astro';
import TagFilter from '../../components/TagFilter.astro';
import { getPublishedCollection } from '../../content/_helpers';
import { getReadingTime } from '../../utils/readingTime';
import { formatDate, isoDate } from '../../utils/formatDate';

const entries = await getPublishedCollection('commentary');
const byDateDesc = (a: typeof entries[number], b: typeof entries[number]) =>
  b.data.publishedDate.getTime() - a.data.publishedDate.getTime();
const pinned = entries.filter((e) => e.data.pinned).sort(byDateDesc);
const sorted = entries.filter((e) => !e.data.pinned).sort(byDateDesc);

// Only tags on filterable (non-pinned) items — the pinned card sits outside
// the filter, so its exclusive tags would render buttons that match nothing.
const allTags = [...new Set(sorted.flatMap((e) => e.data.tags))].sort();

const description =
  'What it actually takes to run AI agents in production — infrastructure patterns, security decisions, and lessons from someone who did the same for cloud a decade ago.';
---

<Base title="Blog — Simon Plant" description={description} jsonLd={{
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Blog — Simon Plant',
  url: new URL('/blog', Astro.site).href,
  description,
}}>
  <main class="section-spacing">
    <div class="container-prose">
      <h1 class="font-serif text-4xl text-gray-50 mb-4">Blog</h1>
      <p class="text-text-secondary text-lg mb-8 font-prose">
        {description}
      </p>

      {pinned.length > 0 && (
        <aside class="mb-10" aria-label="Start here">
          {pinned.map((entry) => (
            <a
              href={`/blog/${entry.id}`}
              class="group block rounded-lg border border-border-subtle bg-surface-card px-5 py-4 hover:border-primary-600 transition-colors"
            >
              <div class="flex items-baseline gap-2 mb-1">
                <span class="text-xs font-sans uppercase tracking-wider text-primary-400">New here? Start here</span>
              </div>
              <h2 class="font-serif text-xl text-gray-50 mb-1 group-hover:text-primary-400 transition-colors">
                {entry.data.title}
              </h2>
              <p class="text-text-secondary font-prose text-sm leading-relaxed">
                {entry.data.description}
              </p>
            </a>
          ))}
        </aside>
      )}

      <TagFilter tags={allTags} itemSelector=".blog-item" eventName="blog_tag_filter" />

      {sorted.length === 0 ? (
        <p class="text-text-muted">Nothing published yet. Check back soon.</p>
      ) : (
        <ol class="space-y-8 list-none p-0" id="blog-list">
          {sorted.map((entry) => (
            <li class="blog-item border-b border-border-subtle pb-8 last:border-b-0" data-tags={entry.data.tags.join(',')}>
              <a href={`/blog/${entry.id}`} class="group block">
                <h2 class="font-serif text-2xl text-gray-50 mb-2 group-hover:text-primary-400 transition-colors">
                  {entry.data.title}
                </h2>
                <p class="text-text-secondary font-prose leading-relaxed mb-3">
                  {entry.data.description}
                </p>
                <div class="flex flex-wrap items-center gap-2 text-sm font-sans">
                  <time class="text-text-muted" datetime={isoDate(entry.data.publishedDate)}>
                    {formatDate(entry.data.publishedDate)}
                  </time>
                  <span class="text-text-muted">&middot;</span>
                  <span class="text-text-muted">{getReadingTime(entry.body)}</span>
                  {entry.data.tags.map((tag) => (
                    <span class="text-primary-400 bg-primary-400/10 px-2 py-0.5 rounded-full text-xs">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </main>
</Base>
